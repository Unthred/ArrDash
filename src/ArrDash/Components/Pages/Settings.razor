        _recentLimits = PanelCatalog.Recent.ToDictionary(
            p => p.Id,
            p => prefs.RecentLimits.TryGetValue(p.Id, out var limit) ? limit : (int?)null);

        _panelHidden = PanelCatalog.All.ToDictionary(
            p => p.Id,
            p => prefs.PanelCollapsed.TryGetValue(p.Id, out var hidden) && hidden);

