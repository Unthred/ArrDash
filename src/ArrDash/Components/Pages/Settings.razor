    private void Cancel()
    {
        ClearLivePreview();
        LoadFromPrefs();
        _ = RefreshService.RefreshAsync(CancellationToken.None);
        Nav.NavigateTo("/");
    }

    private void OnPrefsChanged() => _ = InvokeAsync(async () =>
    {
        if (!Prefs.IsPreviewActive)
            LoadFromPrefs();
        else if (_theme == ThemePreference.System)
            await RefreshSystemAppearanceAsync();

        StateHasChanged();
    });

    private void OnSecretsChanged() => _ = InvokeAsync(() => { RefreshCredentialStatuses(); StateHasChanged(); });

    public void Dispose()
    {
        StopTraktPendingRefresh();
        _debounceTimer?.Dispose();
        Prefs.Changed -= OnPrefsChanged;
        Secrets.Changed -= OnSecretsChanged;
        ThemeService.OnChange -= OnSystemThemeChanged;
    }
}
