    private CancellationTokenSource? _traktPendingRefreshCts;

    private async Task RefreshTraktAccountsAsync()
    {
        try
        {
            _traktAccounts = (await TraktAccounts.ListAccountsAsync()).ToList();
            if (_traktAccounts.Count > 0 && !string.IsNullOrWhiteSpace(_traktPendingUserCode))
            {
                StopTraktPendingRefresh();
                _traktPendingUserCode = null;
                _traktConnectHint = null;
                Snackbar.Add("Trakt account connected", Severity.Success);
            }
        }
        catch
        {
            _traktAccounts = [];
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ConnectTraktAsync()
    {
        _traktBusy = true;
        try
        {
            var (ok, message, device) = await TraktAccounts.StartConnectAsync(CancellationToken.None);
            if (ok && device is not null && !string.IsNullOrWhiteSpace(device.UserCode))
            {
                _traktPendingUserCode = device.UserCode;
                _traktConnectHint = null;
                Snackbar.Add($"Enter {device.UserCode} at trakt.tv/activate", Severity.Info);
                StartTraktPendingRefresh();
            }
            else
            {
                StopTraktPendingRefresh();
                _traktPendingUserCode = null;
                _traktConnectHint = message;
                Snackbar.Add(message, Severity.Warning);
            }
        }
        finally
        {
            _traktBusy = false;
        }
    }

    private void StartTraktPendingRefresh()
    {
        StopTraktPendingRefresh();
        _traktPendingRefreshCts = new CancellationTokenSource();
        var ct = _traktPendingRefreshCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                // Trakt device codes expire after ~10 minutes; poll UI while waiting.
                for (var i = 0; i < 120 && !ct.IsCancellationRequested; i++)
                {
                    await Task.Delay(TimeSpan.FromSeconds(5), ct);
                    await InvokeAsync(RefreshTraktAccountsAsync);
                    if (string.IsNullOrWhiteSpace(_traktPendingUserCode))
                        break;
                }
            }
            catch (OperationCanceledException)
            {
                // ignored
            }
        }, ct);
    }

    private void StopTraktPendingRefresh()
    {
        try { _traktPendingRefreshCts?.Cancel(); } catch { /* ignore */ }
        _traktPendingRefreshCts?.Dispose();
        _traktPendingRefreshCts = null;
    }

    private async Task PreviewTraktAsync(string accountId)
    {
        _traktBusy = true;
        try
        {
            var preview = await TraktSync.PreviewAsync(accountId, CancellationToken.None);
            _traktStatus = $"Preview: import {preview.WouldImport}, link {preview.WouldLinkExisting}, push {preview.WouldPush}, unmatched {preview.Unmatched}";
            Snackbar.Add(_traktStatus, Severity.Info);
            await RefreshTraktAccountsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Trakt preview failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _traktBusy = false;
        }
    }

    private async Task SyncTraktAsync(string accountId)
    {
        if (!TraktSync.TryStartSyncInBackground(accountId, out var message))
        {
            Snackbar.Add($"Sync already running: {message}", Severity.Info);
            return;
        }

        _traktBusy = true;
        _traktStatus = message;
        Snackbar.Add("Trakt sync started — large histories can take a few minutes.", Severity.Info);
        try
        {
            // Poll status until the background import finishes.
            for (var i = 0; i < 600 && TraktSync.IsBusy; i++)
            {
                _traktStatus = TraktSync.StatusMessage;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(1000);
            }

            _traktStatus = TraktSync.StatusMessage;
            Snackbar.Add(_traktStatus, Severity.Success);
            ActivityAnalytics.InvalidateCache();
            WatchStats.InvalidateCache();
            await RefreshTraktAccountsAsync();
        }
        finally
        {
            _traktBusy = false;
        }
    }

    private async Task DisconnectTraktAsync(string accountId)
    {
        _traktBusy = true;
        try
        {
            var (ok, message) = await TraktAccounts.DisconnectAsync(accountId, CancellationToken.None);
            Snackbar.Add(message, ok ? Severity.Success : Severity.Warning);
            await RefreshTraktAccountsAsync();
        }
        finally
        {
            _traktBusy = false;
        }
    }

    private async Task OnTraktCanonicalUserChanged(ArrDash.Data.Entities.TraktAccountEntity account, string? value)
    {
        account.CanonicalUserName = value ?? "";
        await SaveTraktAccountAsync(account);
    }

    private async Task OnTraktMappedUsersChanged(ArrDash.Data.Entities.TraktAccountEntity account, string? value)
    {
        account.MappedUsersJson = ParseMappedUsersJson(value);
        await SaveTraktAccountAsync(account);
    }

    private async Task OnTraktFlagChanged(ArrDash.Data.Entities.TraktAccountEntity account, Action apply)
    {
        apply();
        await SaveTraktAccountAsync(account);
    }

    private async Task SaveTraktAccountAsync(ArrDash.Data.Entities.TraktAccountEntity account)
    {
        var (ok, message) = await TraktAccounts.UpdateAccountAsync(account, CancellationToken.None);
        if (!ok)
            Snackbar.Add(message, Severity.Warning);
    }

    private static string FormatMappedUsers(string json)
    {
        try
        {
            var users = System.Text.Json.JsonSerializer.Deserialize<List<TraktMappedUser>>(json) ?? [];
            return string.Join('\n', users.Select(u => $"{u.Source}|{u.UserName}"));
        }
        catch
        {
            return "";
        }
    }

    private static string ParseMappedUsersJson(string? text)
    {
        var users = (text ?? "")
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(line => line.Split('|', StringSplitOptions.TrimEntries))
            .Where(p => p.Length >= 2)
            .Select(p => new TraktMappedUser { Source = p[0], UserName = p[1], UserId = p.Length > 2 ? p[2] : null })
            .ToList();
        return System.Text.Json.JsonSerializer.Serialize(users);
    }

    private static List<WatchStatsUserAlias> ParseAliases(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return [];

        return text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(line => line.Split('|', StringSplitOptions.TrimEntries))
            .Where(parts => parts.Length == 3 && parts.All(p => !string.IsNullOrWhiteSpace(p)))
            .Select(parts => new WatchStatsUserAlias(parts[0], parts[1], parts[2]))
            .ToList();
    }

