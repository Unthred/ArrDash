    private void ScheduleLivePreviewDebounced()
    {
        SyncDraftFromForm();
        ScheduleLivePreview(debounce: true);
    }

    private void ScheduleLivePreviewNow()
    {
        SyncDraftFromForm();
        ScheduleLivePreview(debounce: false);
    }

    private void ScheduleLivePreview(bool debounce)
    {
        if (debounce)
        {
            _debounceTimer?.Dispose();
            _debounceTimer = new System.Threading.Timer(_ =>
                _ = InvokeAsync(PushLivePreviewAsync), null, 350, Timeout.Infinite);
            return;
        }

        _ = PushLivePreviewAsync();
    }

    private async Task PushLivePreviewAsync()
    {
        var prefs = new UserLayoutPreferences();
        ApplyFormToPrefs(prefs);
        var secretUpdates = BuildSecretUpdates();
        var hasPrefChanges = Prefs.DiffersFromSaved(prefs);
        var hasSecretChanges = HasAnySecretInput(secretUpdates);

        if (!hasPrefChanges && !hasSecretChanges)
        {
            ClearLivePreview();
            Prefs.ClearSettingsDraft();
            await RefreshService.RefreshAsync(CancellationToken.None);
            return;
        }

        Prefs.SetSettingsDraft(prefs);
        Prefs.SetPreview(prefs);
        CredentialsPreview.Set(hasSecretChanges ? secretUpdates : null);
        OptionsAccessor.Reload();
        await RefreshService.RefreshAsync(CancellationToken.None);
    }

    private void ClearLivePreview()
    {
        _debounceTimer?.Dispose();
        Prefs.ClearPreview();
        Prefs.ClearSettingsDraft();
        CredentialsPreview.Clear();
        OptionsAccessor.Reload();
    }

    private async Task PreviewDashboardAsync()
    {
        _debounceTimer?.Dispose();
        SyncDraftFromForm();
        await PushLivePreviewAsync();
        Nav.NavigateTo("/");
    }

    private ServiceTestInput BuildTestInput(string serviceKey)
    {
        _urlInputs.TryGetValue(serviceKey, out var url);
        _credentialInputs.TryGetValue(serviceKey, out var key);
        return new ServiceTestInput(
            string.IsNullOrWhiteSpace(url) ? null : url.Trim(),
            string.IsNullOrWhiteSpace(key) ? null : key.Trim());
    }

    private async Task TestConnectionAsync(string serviceKey)
    {
        _testing.Add(serviceKey);
        try
        {
            var (ok, message) = await ConnectionTester.TestAsync(serviceKey, BuildTestInput(serviceKey), CancellationToken.None);
            var label = _credentialStatuses.FirstOrDefault(c => c.Key == serviceKey)?.Label ?? serviceKey;
            Snackbar.Add($"{label}: {message}", ok ? Severity.Success : Severity.Warning);
        }
        finally
        {
            _testing.Remove(serviceKey);
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            var prefs = BuildFormPrefs();
            await Prefs.SaveAsync(prefs);
            await ThemeService.SetPreferenceAsync(_theme);
            CredentialsPreview.Clear();

            var secretUpdates = BuildSecretUpdates();
            if (HasAnySecretInput(secretUpdates))
            {
                await Secrets.SavePartialAsync(secretUpdates);
                OptionsAccessor.Reload();
            }

            await RefreshService.RefreshAsync(CancellationToken.None);
            ActivityAnalytics.InvalidateCache();
            WatchStats.InvalidateCache();

            foreach (var key in _credentialInputs.Keys.ToList())
                _credentialInputs[key] = "";
            foreach (var key in _urlInputs.Keys.ToList())
                _urlInputs[key] = "";
            _traktClientSecretInput = "";

            RefreshCredentialStatuses();
            Snackbar.Add("Settings saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

