    private void RefreshCredentialStatuses()
    {
        var configured = Secrets.GetConfiguredFlags(OptionsAccessor.Options);
        var hints = Secrets.GetMaskedHints();
        var urls = Secrets.GetCurrentUrls(OptionsAccessor.Options);
        _credentialStatuses = ServiceCredentialCatalog.BuildStatuses(configured, hints, urls);

        foreach (var cred in _credentialStatuses)
        {
            _credentialInputs.TryAdd(cred.Key, "");
            _urlInputs.TryAdd(cred.Key, "");
            _serviceEnabled.TryAdd(cred.Key, true);
        }

        if (_credentialStatuses.All(c => c.Key != _selectedServiceKey))
            _selectedServiceKey = _credentialStatuses.FirstOrDefault()?.Key ?? "sonarr";
    }

