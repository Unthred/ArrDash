@page "/settings"
@inject LayoutPreferencesService Prefs
@inject ThemeService ThemeService
@inject ServiceCredentialsPreviewService CredentialsPreview
@inject ServiceSecretsStore Secrets
@inject MediaServiceOptionsAccessor OptionsAccessor
@inject DashboardRefreshService RefreshService
@inject ServiceConnectionTester ConnectionTester
@inject WatchStatsLibraryCatalog LibraryCatalog
@inject ActivityAnalyticsService ActivityAnalytics
@inject WatchStatsService WatchStats
@inject TraktAccountService TraktAccounts
@inject TraktSyncService TraktSync
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>ArrDash Settings</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="settings-page">
    <div class="settings-header-row">
        <div>
            <h1 class="settings-title">Settings</h1>
            <p class="settings-lead muted">Most layout changes apply on the dashboard — use Preview dashboard to see them before saving.</p>
        </div>
    </div>

    <div class="settings-toolbar">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_saving" Size="Size.Small">
            @(_saving ? "Saving…" : "Save")
        </MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel" Size="Size.Small">Discard</MudButton>
        <MudButton Variant="@(Prefs.IsPreviewActive ? Variant.Filled : Variant.Text)"
                   Color="@(Prefs.IsPreviewActive ? Color.Warning : Color.Default)"
                   StartIcon="@Icons.Material.Filled.Dashboard"
                   OnClick="PreviewDashboardAsync"
                   Size="Size.Small">
            Preview dashboard
        </MudButton>
        @if (Prefs.IsPreviewActive)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Unsaved — open Preview dashboard</MudChip>
        }
        <div class="settings-toolbar-spacer"></div>
        <MudSwitch @bind-Value="_showSettingsHelp"
                   @bind-Value:after="PersistShowSettingsHelpAsync"
                   Color="Color.Primary"
                   Label="Show help"
                   Class="settings-help-toggle" />
    </div>

    <CascadingValue Value="_showSettingsHelp">
    <MudTabs Class="settings-tabs" Rounded="true" ApplyEffectsToContainer="true" PanelClass="settings-tab-panel settings-tab-fit">
        <MudTabPanel Text="Layout" Icon="@Icons.Material.Filled.Dashboard">
            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-section-title">Display</div>
                <div class="settings-grid-2">
                    <SettingField Text="@SettingsHelpTexts.DashboardTitle">
                        <MudTextField @bind-Value="_dashboardTitle" @bind-Value:after="ScheduleLivePreviewDebounced" Label="Dashboard title" Variant="Variant.Outlined" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.HideHeroStrip" Class="settings-switch-cell">
                        <MudSwitch @bind-Value="_hideHeroStrip" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Hide hero strip" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.DashboardSubtitle" Span2="true">
                        <MudTextField @bind-Value="_dashboardSubtitle" @bind-Value:after="ScheduleLivePreviewDebounced" Label="Subtitle" Variant="Variant.Outlined" Lines="2" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.PosterSize">
                        <MudSelect T="PosterSize" @bind-Value="_posterSize" @bind-Value:after="ScheduleLivePreviewNow" Label="Poster size" Variant="Variant.Outlined">
                            <MudSelectItem Value="PosterSize.Small">Small</MudSelectItem>
                            <MudSelectItem Value="PosterSize.Medium">Medium</MudSelectItem>
                            <MudSelectItem Value="PosterSize.Large">Large</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.PosterPlacement">
                        <MudSelect T="PosterPlacement" @bind-Value="_posterPlacement" @bind-Value:after="ScheduleLivePreviewNow" Label="Poster placement" Variant="Variant.Outlined">
                            <MudSelectItem Value="PosterPlacement.Left">Left</MudSelectItem>
                            <MudSelectItem Value="PosterPlacement.Top">Top</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowQuality">
                        <MudSwitch @bind-Value="_showQuality" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Quality labels" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowEpisodeBadges">
                        <MudSwitch @bind-Value="_showEpisodeBadges" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Episode badges" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowMissingEpisodes">
                        <MudSwitch @bind-Value="_showMissingEpisodes" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Highlight missing episodes" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowSyncNotes">
                        <MudSwitch @bind-Value="_showSyncNotes" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Audiobook sync notes" />
                    </SettingField>
                </div>
            </MudPaper>

            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-section-title">Service status</div>
                <div class="settings-grid-2">
                    <SettingField Text="@SettingsHelpTexts.StatusBar">
                        <MudSelect T="StatusBarMode" @bind-Value="_statusBarMode" @bind-Value:after="ScheduleLivePreviewNow" Label="Status bar" Variant="Variant.Outlined">
                            <MudSelectItem Value="StatusBarMode.All">All services</MudSelectItem>
                            <MudSelectItem Value="StatusBarMode.OfflineOnly">Offline only</MudSelectItem>
                            <MudSelectItem Value="StatusBarMode.Hidden">Hidden</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.StatusBarAlignment">
                        <MudSelect T="StatusBarAlignment" @bind-Value="_statusBarAlignment" @bind-Value:after="ScheduleLivePreviewNow" Label="Status bar layout" Variant="Variant.Outlined">
                            <MudSelectItem Value="StatusBarAlignment.Left">Left aligned</MudSelectItem>
                            <MudSelectItem Value="StatusBarAlignment.Right">Right aligned</MudSelectItem>
                            <MudSelectItem Value="StatusBarAlignment.SpacedEvenly">Spaced evenly</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.PollInterval">
                        <MudNumericField @bind-Value="_pollIntervalSeconds" @bind-Value:after="ScheduleLivePreviewNow" Label="Poll interval (sec)" Variant="Variant.Outlined" Min="0" Max="3600" HelperText="0 = env default" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ManualRefreshOnly">
                        <MudSwitch @bind-Value="_manualRefreshOnly" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Manual refresh only" />
                    </SettingField>
                </div>
            </MudPaper>

            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-section-title">Network breakdown</div>
                <div class="settings-grid-2">
                    <SettingField Text="@SettingsHelpTexts.NetworkPieChartSize">
                        <MudSlider @bind-Value="_networkPieChartSize" @bind-Value:after="ScheduleLivePreviewNow" Min="32" Max="320" Step="4" Color="Color.Primary">Pie chart size: @(_networkPieChartSize)px</MudSlider>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.NetworkPieStyle">
                        <MudSelect T="NetworkPieStyle" @bind-Value="_networkPieStyle" @bind-Value:after="ScheduleLivePreviewNow" Label="Pie style" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="NetworkPieStyle.Flat">Flat</MudSelectItem>
                            <MudSelectItem Value="NetworkPieStyle.Soft">Soft shadow</MudSelectItem>
                            <MudSelectItem Value="NetworkPieStyle.Glossy">Glossy</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.NetworkPieShowSliceLabels">
                        <MudSwitch @bind-Value="_networkPieShowSliceLabels" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Show % labels on slices" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.NetworkLegendShowPercent">
                        <MudSwitch @bind-Value="_networkLegendShowPercent" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Show % in legend" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.NetworkLegendShowRate">
                        <MudSwitch @bind-Value="_networkLegendShowRate" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Show speed in legend" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.NetworkLegendShowCpu">
                        <MudSwitch @bind-Value="_networkLegendShowCpu" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Show CPU % in legend" />
                    </SettingField>
                </div>
            </MudPaper>

            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-section-title">Panels</div>
                <SettingSectionHelp Text="@SettingsHelpTexts.PanelOrder" />
                <div class="panel-order-compact">
                    @for (var i = 0; i < _panelOrder.Count; i++)
                    {
                        var panelId = _panelOrder[i];
                        <div class="panel-order-row">
                            <MudText Class="panel-order-label">@PanelCatalog.LabelFor(panelId)</MudText>
                            <div class="panel-order-actions">
                                <MudSwitch @bind-Value="_panelHidden[panelId]" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Hide" />
                                <MudSelect T="PanelViewMode" @bind-Value="_panelViewModes[panelId]" @bind-Value:after="ScheduleLivePreviewNow" Label="View" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Class="panel-view-select">
                                    <MudSelectItem Value="PanelViewMode.Cards">Cards</MudSelectItem>
                                    <MudSelectItem Value="PanelViewMode.Compact">List</MudSelectItem>
                                    <MudSelectItem Value="PanelViewMode.Table">Table</MudSelectItem>
                                </MudSelect>
                            </div>
                        </div>
                    }
                </div>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Appearance" Icon="@Icons.Material.Filled.Palette">
            <MudPaper Class="settings-section compact appearance-panel" Elevation="0">
                <div class="appearance-row appearance-row--theme">
                    <div class="appearance-section appearance-section--flat">
                        <div class="settings-section-title">Theme</div>
                        <SettingField Text="@SettingsHelpTexts.Theme">
                            <MudToggleGroup T="ThemePreference"
                                            @bind-Value="_theme"
                                            @bind-Value:after="OnThemePreferenceChangedAsync"
                                            Color="Color.Default"
                                            Rounded="true"
                                            SelectedClass="segmented-toggle-selected"
                                            Class="arrdash-segmented-toggle theme-toggle settings-theme-toggle"
                                            FixedContent>
                                <MudToggleItem Value="ThemePreference.Light" Text="Light" />
                                <MudToggleItem Value="ThemePreference.Dark" Text="Dark" />
                                <MudToggleItem Value="ThemePreference.System" Text="System" />
                            </MudToggleGroup>
                        </SettingField>
                        @if (_theme == ThemePreference.System)
                        {
                            <p class="appearance-system-hint muted">
                                Using <strong>@(_systemIsDark ? "dark" : "light")</strong> from system preference.
                            </p>
                        }
                    </div>
                </div>

                <div class="settings-grid-4 appearance-layout-row">
                    <SettingField Text="@SettingsHelpTexts.Density">
                        <MudSelect T="LayoutDensity" Value="@_density" ValueChanged="OnDensityChanged" Label="Density" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="LayoutDensity.Comfortable">Comfortable</MudSelectItem>
                            <MudSelectItem Value="LayoutDensity.Compact">Compact</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.BorderRadius">
                        <MudSelect T="BorderRadiusStyle" Value="@_borderRadius" ValueChanged="OnBorderRadiusChanged" Label="Card corners" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="BorderRadiusStyle.Rounded">Rounded</MudSelectItem>
                            <MudSelectItem Value="BorderRadiusStyle.Sharp">Sharp</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.BrandMark">
                        <MudTextField Value="@_brandMark" ValueChanged="@((string v) => OnBrandMarkChanged(v))" Label="Brand mark" Variant="Variant.Outlined" MaxLength="3" Margin="Margin.Dense" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.BackgroundStyle">
                        <MudSelect T="BackgroundStyle" @bind-Value="_backgroundStyle" @bind-Value:after="ScheduleLivePreviewNow" Label="Background style" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="BackgroundStyle.Gradient">Gradient</MudSelectItem>
                            <MudSelectItem Value="BackgroundStyle.Solid">Solid</MudSelectItem>
                            <MudSelectItem Value="BackgroundStyle.Minimal">Minimal</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                </div>

                <div class="appearance-row appearance-row--accent">
                    <div class="appearance-color-card appearance-color-card--accent">
                        <SettingField Text="@SettingsHelpTexts.AccentColor">
                            <PresetColorField Label="Accent colour"
                                              Hint="Buttons, links, and highlights."
                                              @bind-Value="_primaryColor"
                                              @bind-Value:after="ScheduleLivePreviewDebounced"
                                              Presets="AppearanceColorPresets.Accent"
                                              DefaultColor="@AppearanceColorPresets.DefaultAccent">
                                <Preview>
                                    <div class="appearance-accent-preview">
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">Sample</MudButton>
                                        <span class="appearance-accent-link">Sample link</span>
                                    </div>
                                </Preview>
                            </PresetColorField>
                        </SettingField>
                    </div>
                </div>

                @if (_theme == ThemePreference.System)
                {
                    <SettingSectionHelp Text="@SettingsHelpTexts.TextColorSystem(_systemIsDark)" />
                    <div class="appearance-mode-grid">
                        <div class="appearance-color-card">
                            <SettingField Text="@SettingsHelpTexts.LightBackgroundColor">
                                @RenderBackgroundColorField(isLightMode: true)
                            </SettingField>
                        </div>
                        <div class="appearance-color-card">
                            <SettingField Text="@SettingsHelpTexts.DarkBackgroundColor">
                                @RenderBackgroundColorField(isLightMode: false)
                            </SettingField>
                        </div>
                        <div class="appearance-color-card">
                            <SettingField Text="@SettingsHelpTexts.LightTextColor">
                                @RenderTextColorField(isLightMode: true)
                            </SettingField>
                        </div>
                        <div class="appearance-color-card">
                            <SettingField Text="@SettingsHelpTexts.DarkTextColor">
                                @RenderTextColorField(isLightMode: false)
                            </SettingField>
                        </div>
                    </div>
                }
                else
                {
                    <div class="appearance-mode-grid appearance-mode-grid--single">
                        <div class="appearance-color-card">
                            <SettingField Text="@(_theme == ThemePreference.Light ? SettingsHelpTexts.LightBackgroundColor : SettingsHelpTexts.DarkBackgroundColor)">
                                @RenderBackgroundColorField(_theme == ThemePreference.Light)
                            </SettingField>
                        </div>
                        <div class="appearance-color-card">
                            <SettingField Text="@(_theme == ThemePreference.Light ? SettingsHelpTexts.LightTextColor : SettingsHelpTexts.DarkTextColor)">
                                @RenderTextColorField(_theme == ThemePreference.Light)
                            </SettingField>
                        </div>
                    </div>
                }

                <div class="settings-section-title">Panel colours</div>
                <SettingSectionHelp Text="Accent colours used for each panel heading and highlights." />
                <div class="settings-grid-3 accent-grid">
                    @foreach (var panel in PanelCatalog.All)
                    {
                        <SettingField Text="@SettingsHelpTexts.PanelAccent(panel.Label)">
                            <ColorPickerField Label="@panel.Label"
                                              Value="@_panelAccentColors[panel.Id]"
                                              ValueChanged="@(color => OnPanelAccentChanged(panel.Id, color))"
                                              DefaultColor="@panel.DefaultAccent"
                                              AllowDefault="true" />
                        </SettingField>
                    }
                </div>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Lists" Icon="@Icons.Material.Filled.List">
            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-grid-2">
                    <SettingField Text="@SettingsHelpTexts.RecentWindow">
                        <MudSelect T="RecentWindowMode" @bind-Value="_recentWindowMode" @bind-Value:after="ScheduleLivePreviewNow" Label="Recent window" Variant="Variant.Outlined">
                            <MudSelectItem Value="RecentWindowMode.ItemCount">Item count</MudSelectItem>
                            <MudSelectItem Value="RecentWindowMode.Days">Last N days</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.TimeFormat">
                        <MudSelect T="TimeDisplayFormat" @bind-Value="_timeFormat" @bind-Value:after="ScheduleLivePreviewNow" Label="Time display" Variant="Variant.Outlined">
                            <MudSelectItem Value="TimeDisplayFormat.Relative">Relative</MudSelectItem>
                            <MudSelectItem Value="TimeDisplayFormat.Clock">Clock</MudSelectItem>
                            <MudSelectItem Value="TimeDisplayFormat.DateTime">Date + time</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    @if (_recentWindowMode == RecentWindowMode.Days)
                    {
                        <SettingField Text="@SettingsHelpTexts.RecentDays">
                            <MudNumericField @bind-Value="_recentDays" @bind-Value:after="ScheduleLivePreviewNow" Label="Days" Variant="Variant.Outlined" Min="1" Max="365" />
                        </SettingField>
                    }
                    <SettingField Text="@SettingsHelpTexts.DefaultRecentLimit">
                        <MudNumericField @bind-Value="_defaultRecentLimit" @bind-Value:after="ScheduleLivePreviewNow" Label="Default list size" Variant="Variant.Outlined" Min="5" Max="100" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.AudiobookSource" Span2="true">
                        <MudSelect T="AudiobookSourceMode" @bind-Value="_audiobookSource" @bind-Value:after="ScheduleLivePreviewNow" Label="Audiobook source" Variant="Variant.Outlined">
                            <MudSelectItem Value="AudiobookSourceMode.Merge">Merge Chaptarr + ABS</MudSelectItem>
                            <MudSelectItem Value="AudiobookSourceMode.ChaptarrOnly">Chaptarr only</MudSelectItem>
                            <MudSelectItem Value="AudiobookSourceMode.AudiobookShelfOnly">AudioBookShelf only</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    @foreach (var panel in PanelCatalog.Recent)
                    {
                        <SettingField Text="@SettingsHelpTexts.PanelRecentLimit(panel.Label)">
                            <MudNumericField @bind-Value="_recentLimits[panel.Id]"
                                             @bind-Value:after="ScheduleLivePreviewNow"
                                             Label="@panel.Label"
                                             Variant="Variant.Outlined"
                                             Min="5"
                                             Max="100"
                                             Disabled="@(_recentWindowMode == RecentWindowMode.Days)" />
                        </SettingField>
                    }
                </div>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Playback" Icon="@Icons.Material.Filled.PlayCircle">
            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-grid-2">
                    <SettingField Text="@SettingsHelpTexts.ShowPlexSessions">
                        <MudSwitch @bind-Value="_showPlexSessions" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Plex sessions" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowEmbySessions">
                        <MudSwitch @bind-Value="_showEmbySessions" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Emby sessions" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowJellyfinSessions">
                        <MudSwitch @bind-Value="_showJellyfinSessions" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Jellyfin sessions" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.HideIdleSessions">
                        <MudSwitch @bind-Value="_hideIdleSessions" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Hide idle (0%)" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowServerMetrics">
                        <MudSwitch @bind-Value="_showServerMetrics" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Show server CPU, memory & disk" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.MetricsPollInterval">
                        <MudNumericField @bind-Value="_metricsPollIntervalSeconds" @bind-Value:after="ScheduleLivePreviewNow" Label="Server metrics interval (sec)" Variant="Variant.Outlined" Min="0" Max="60" Disabled="@(!_showServerMetrics)" HelperText="0 = default (2 sec)" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.MetricsGraphWindow">
                        <MudNumericField @bind-Value="_metricsGraphWindowMinutes" @bind-Value:after="ScheduleLivePreviewNow" Label="CPU graph window (min)" Variant="Variant.Outlined" Min="0" Max="240" Disabled="@(!_showServerMetrics)" HelperText="0 = default (15 min)" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.MetricsHostLabel">
                        <MudTextField @bind-Value="_metricsHostLabel" @bind-Value:after="ScheduleLivePreviewDebounced" Label="Host label" Variant="Variant.Outlined" Disabled="@(!_showServerMetrics)" Placeholder="Host" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.MetricsDiskPath">
                        <MudTextField @bind-Value="_metricsDiskPath" @bind-Value:after="ScheduleLivePreviewDebounced" Label="Disk path(s)" Variant="Variant.Outlined" Disabled="@(!_showServerMetrics)" Placeholder="/" HelperText="Comma-separated; mount paths inside the container" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.EnableClickThrough">
                        <MudSwitch @bind-Value="_enableClickThrough" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Click-through links" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.DeepLinkClickThrough">
                        <MudSwitch @bind-Value="_deepLinkClickThrough" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Open specific item" Disabled="@(!_enableClickThrough)" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ExternalLinkTarget">
                        <MudSelect T="ExternalLinkTarget" @bind-Value="_externalLinkTarget" @bind-Value:after="ScheduleLivePreviewNow" Label="Open links in" Variant="Variant.Outlined" Disabled="@(!_enableClickThrough)">
                            <MudSelectItem Value="ExternalLinkTarget.NewTab">New tab</MudSelectItem>
                            <MudSelectItem Value="ExternalLinkTarget.SameTab">Same tab</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.MissingEpisodeClickAction">
                        <MudSelect T="MissingEpisodeClickAction" @bind-Value="_missingEpisodeClickAction" @bind-Value:after="ScheduleLivePreviewNow" Label="Missing episode click" Variant="Variant.Outlined" Disabled="@(!_showMissingEpisodes)">
                            <MudSelectItem Value="MissingEpisodeClickAction.SearchOnly">Search only</MudSelectItem>
                            <MudSelectItem Value="MissingEpisodeClickAction.OpenSonarrAndSearch">Open Sonarr and search</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.FriendlyQualityLabels">
                        <MudSwitch @bind-Value="_friendlyQualityLabels" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Friendly quality labels" Disabled="@(!_showQuality)" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.StartupPage">
                        <MudSelect T="StartupPage" @bind-Value="_startupPage" @bind-Value:after="ScheduleLivePreviewNow" Label="Startup page" Variant="Variant.Outlined">
                            <MudSelectItem Value="StartupPage.Dashboard">Dashboard</MudSelectItem>
                            <MudSelectItem Value="StartupPage.Settings">Settings</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                </div>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Watch Stats" Icon="@Icons.Material.Filled.Insights">
            <MudPaper Class="settings-section compact" Elevation="0">
                <SettingField Text="@SettingsHelpTexts.WatchStatsLiveSources" Span2="true">
                    <div class="watch-stats-source-list">
                        @{
                            var tautulli = _credentialStatuses.FirstOrDefault(c => c.Key == "tautulli");
                            var tracearr = _credentialStatuses.FirstOrDefault(c => c.Key == "tracearr");
                        }
                        <div class="watch-stats-source-row">
                            <div>
                                <MudText Typo="Typo.subtitle2">Tautulli (Plex)</MudText>
                                <MudText Typo="Typo.caption" Class="muted">@SettingsHelpTexts.WatchStatsTautulliSource</MudText>
                            </div>
                            <MudChip T="string" Size="Size.Small" Color="@(tautulli?.Configured == true ? Color.Success : Color.Default)" Variant="Variant.Outlined">
                                @(tautulli?.Configured == true ? "Configured" : "Not set")
                            </MudChip>
                        </div>
                        <div class="watch-stats-source-row">
                            <div>
                                <MudText Typo="Typo.subtitle2">Tracearr (Emby / Jellyfin)</MudText>
                                <MudText Typo="Typo.caption" Class="muted">@SettingsHelpTexts.WatchStatsTracearrSource</MudText>
                            </div>
                            <MudChip T="string" Size="Size.Small" Color="@(tracearr?.Configured == true ? Color.Success : Color.Default)" Variant="Variant.Outlined">
                                @(tracearr?.Configured == true ? "Configured" : "Not set")
                            </MudChip>
                        </div>
                        <MudText Typo="Typo.caption" Class="muted mt-2">Set credentials on the API keys tab (Tautulli + Tracearr).</MudText>
                    </div>
                </SettingField>
                <div class="settings-grid-2">
                    <SettingField Text="@SettingsHelpTexts.WatchStatsSyncEnabled">
                        <MudSwitch @bind-Value="_watchStatsSyncEnabled" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Enable history sync" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.WatchStatsSyncInterval">
                        <MudNumericField @bind-Value="_watchStatsSyncIntervalMinutes" @bind-Value:after="ScheduleLivePreviewNow" Label="Sync interval (min)" Variant="Variant.Outlined" Min="0" Max="240" Disabled="@(!_watchStatsSyncEnabled)" HelperText="0 = default (20 min)" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.WatchStatsBackfillDays">
                        <MudNumericField @bind-Value="_watchStatsBackfillDays" @bind-Value:after="ScheduleLivePreviewNow" Label="Backfill days" Variant="Variant.Outlined" Min="0" Max="730" Disabled="@(!_watchStatsSyncEnabled)" HelperText="0 = default (90 days)" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.WatchStatsRetentionDays">
                        <MudNumericField @bind-Value="_watchStatsRetentionDays" @bind-Value:after="ScheduleLivePreviewNow" Label="Retention days" Variant="Variant.Outlined" Min="0" Max="1825" Disabled="@(!_watchStatsSyncEnabled)" HelperText="0 = default (365 days)" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.WatchStatsSyncPlex">
                        <MudSwitch @bind-Value="_watchStatsSyncPlex" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Sync Plex (Tautulli)" Disabled="@(!_watchStatsSyncEnabled)" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.WatchStatsSyncEmby">
                        <MudSwitch @bind-Value="_watchStatsSyncEmby" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Sync Emby" Disabled="@(!_watchStatsSyncEnabled)" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.WatchStatsSyncJellyfin">
                        <MudSwitch @bind-Value="_watchStatsSyncJellyfin" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Sync Jellyfin" Disabled="@(!_watchStatsSyncEnabled)" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowCombinedWatchStats">
                        <MudSwitch @bind-Value="_showCombinedWatchStats" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Show combined view" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowPlexWatchStats">
                        <MudSwitch @bind-Value="_showPlexWatchStats" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Show Plex stats" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowEmbyWatchStats">
                        <MudSwitch @bind-Value="_showEmbyWatchStats" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Show Emby stats" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ShowJellyfinWatchStats">
                        <MudSwitch @bind-Value="_showJellyfinWatchStats" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Show Jellyfin stats" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.WatchStatsTopLimit">
                        <MudNumericField @bind-Value="_watchStatsTopLimit" @bind-Value:after="ScheduleLivePreviewNow" Label="Leaderboard size" Variant="Variant.Outlined" Min="3" Max="25" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.WatchStatsUserAliases" Span2="true">
                        <MudTextField @bind-Value="_watchStatsAliasesText" @bind-Value:after="ScheduleLivePreviewDebounced" Label="User aliases" Variant="Variant.Outlined" Lines="4" Placeholder="Mom|plex|Margaret&#10;Mom|emby|Margaret" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.WatchStatsIncludedLibraries" Span2="true">
                        <div class="d-flex align-center gap-2 mb-2">
                            <MudText Typo="Typo.subtitle2">Libraries in Activity reports</MudText>
                            <MudSpacer />
                            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="SelectAllLibraries" Disabled="@(_libraryCatalog.Count == 0)">Include all</MudButton>
                            <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="RefreshLibraryCatalogAsync" Disabled="_librariesLoading">
                                @(_librariesLoading ? "Loading…" : "Refresh")
                            </MudButton>
                        </div>
                        @if (_librariesLoading && _libraryCatalog.Count == 0)
                        {
                            <MudText Typo="Typo.caption" Class="muted">Loading libraries…</MudText>
                        }
                        else if (_libraryCatalog.Count == 0)
                        {
                            <MudText Typo="Typo.caption" Class="muted">No libraries discovered yet. Run a history sync, then Refresh.</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Class="muted mb-2">
                                @(_excludedLibraryKeys.Count == 0
                                    ? "All libraries included. Uncheck any to hide it from Activity and keep it out of Trakt push (saved immediately)."
                                    : $"{_excludedLibraryKeys.Count} of {_libraryCatalog.Count} libraries excluded from Activity and Trakt push (saved immediately).")
                            </MudText>
                            @foreach (var group in _libraryCatalog.GroupBy(l => l.Source))
                            {
                                <MudText Typo="Typo.caption" Class="mt-2 mb-1"><b>@WatchStatsSources.Label(group.Key)</b></MudText>
                                @foreach (var lib in group)
                                {
                                    <MudCheckBox T="bool"
                                                 Value="@IsLibraryIncluded(lib.Key)"
                                                 ValueChanged="@(async v => await ToggleLibrary(lib.Key, v))"
                                                 Label="@LibraryCheckboxLabel(lib)"
                                                 Dense="true"
                                                 Color="Color.Primary" />
                                }
                            }
                        }
                    </SettingField>
                </div>

                <div class="settings-section-title mt-4">Trakt</div>
                <MudText Typo="Typo.caption" Class="muted mb-2">
                    Connect Trakt accounts to restore watched history into ArrDash (and optionally push new plays). Additive only — never deletes.
                    Register an app at trakt.tv/oauth/applications and set Client ID/Secret on the API keys tab.
                    Connect uses the same PIN flow as other apps: ArrDash shows a code → you enter it at trakt.tv/activate.
                </MudText>
                <div class="d-flex gap-2 mb-2">
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="ConnectTraktAsync" Disabled="_traktBusy">
                        Connect Trakt account
                    </MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="RefreshTraktAccountsAsync" Disabled="_traktBusy">
                        Refresh
                    </MudButton>
                </div>
                <SettingField Text="@SettingsHelpTexts.TraktPosterMode">
                    <MudSelect T="string" Value="_traktPosterMode" ValueChanged="OnTraktPosterModeChanged"
                               Label="Trakt posters" Variant="Variant.Outlined" Dense="true">
                        <MudSelectItem T="string" Value="@("both")">Library match, TMDB fallback</MudSelectItem>
                        <MudSelectItem T="string" Value="@("library")">Library match only</MudSelectItem>
                        <MudSelectItem T="string" Value="@("tmdb")">TMDB only</MudSelectItem>
                        <MudSelectItem T="string" Value="@("off")">Off</MudSelectItem>
                    </MudSelect>
                </SettingField>
                @if (!string.IsNullOrWhiteSpace(_traktPendingUserCode))
                {
                    <MudAlert Severity="Severity.Info" Class="mb-2" Dense="false">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Authorize with PIN</MudText>
                        <MudText Typo="Typo.body2" Class="mb-2">
                            1. Open
                            <MudLink Href="https://trakt.tv/activate" Target="_blank" Rel="noopener">trakt.tv/activate</MudLink>
                            (sign in if asked)<br />
                            2. Enter this code and allow access:<br />
                            <span style="font-size:1.75rem;font-weight:700;letter-spacing:0.2em;font-family:ui-monospace,monospace;">@_traktPendingUserCode</span>
                        </MudText>
                        <MudText Typo="Typo.caption" Class="muted">
                            ArrDash polls automatically — click Refresh after approving if the account does not appear.
                        </MudText>
                    </MudAlert>
                }
                else if (!string.IsNullOrWhiteSpace(_traktConnectHint))
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">@_traktConnectHint</MudAlert>
                }
                @if (_traktAccounts.Count == 0)
                {
                    <MudText Typo="Typo.caption" Class="muted">No Trakt accounts connected yet.</MudText>
                }
                else
                {
                    @foreach (var account in _traktAccounts)
                    {
                        <MudPaper Class="pa-3 mb-2" Elevation="0" Outlined="true">
                            <div class="d-flex align-center gap-2 mb-2">
                                <MudText Typo="Typo.subtitle2">@account.TraktUsername</MudText>
                                <MudSpacer />
                                <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => PreviewTraktAsync(account.Id))" Disabled="_traktBusy">Preview</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                           OnClick="@(() => SyncTraktAsync(account.Id))" Disabled="_traktBusy || account.LastPreviewAtUtc is null">
                                    Sync now
                                </MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                           OnClick="@(() => DisconnectTraktAsync(account.Id))" Disabled="_traktBusy">
                                    Disconnect
                                </MudButton>
                            </div>
                            <div class="settings-grid-2">
                                <MudTextField Value="@account.CanonicalUserName"
                                              ValueChanged="@((string? v) => OnTraktCanonicalUserChanged(account, v))"
                                              Label="Canonical ArrDash username" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                <MudTextField Value="@FormatMappedUsers(account.MappedUsersJson)"
                                              ValueChanged="@((string? v) => OnTraktMappedUsersChanged(account, v))"
                                              Label="Mapped users (source|name per line)" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2"
                                              HelperText="e.g. emby|Squiggley" />
                                <MudSwitch T="bool" Value="@account.SyncMovies" ValueChanged="@(v => OnTraktFlagChanged(account, () => account.SyncMovies = v))" Color="Color.Primary" Label="Movies" />
                                <MudSwitch T="bool" Value="@account.SyncEpisodes" ValueChanged="@(v => OnTraktFlagChanged(account, () => account.SyncEpisodes = v))" Color="Color.Primary" Label="Episodes" />
                                <MudSwitch T="bool" Value="@account.ImportToWarehouse" ValueChanged="@(v => OnTraktFlagChanged(account, () => account.ImportToWarehouse = v))" Color="Color.Primary" Label="Import into ArrDash" />
                                <MudSwitch T="bool" Value="@account.PushToTrakt" ValueChanged="@(v => OnTraktFlagChanged(account, () => account.PushToTrakt = v))" Color="Color.Primary" Label="Push new plays to Trakt" />
                                <MudSwitch T="bool" Value="@account.MarkEmbyWatched" ValueChanged="@(v => OnTraktFlagChanged(account, () => account.MarkEmbyWatched = v))" Color="Color.Primary" Label="Mark Emby watched (preview-gated)" />
                                <MudSwitch T="bool" Value="@account.MarkPlexWatched" ValueChanged="@(v => OnTraktFlagChanged(account, () => account.MarkPlexWatched = v))" Color="Color.Primary" Label="Mark Plex watched (preview-gated)" />
                            </div>
                            <MudText Typo="Typo.caption" Class="muted mt-1">
                                @(account.LastPreviewAtUtc is null ? "Run Preview before Sync." : $"Last preview {account.LastPreviewAtUtc:u}")
                                @if (account.LastSyncedAtUtc is not null)
                                {
                                    <text> · Last sync @account.LastSyncedAtUtc.Value.ToString("u")</text>
                                }
                            </MudText>
                        </MudPaper>
                    }
                }
                @if (!string.IsNullOrWhiteSpace(_traktStatus) || TraktSync.IsBusy)
                {
                    <MudText Typo="Typo.caption" Class="mt-1">
                        @(TraktSync.IsBusy ? TraktSync.StatusMessage : _traktStatus)
                    </MudText>
                }
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Kiosk" Icon="@Icons.Material.Filled.Tv">
            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-grid-2">
                    <SettingField Text="@SettingsHelpTexts.AutoKioskOnLoad">
                        <MudSwitch @bind-Value="_autoKioskOnLoad" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Kiosk on load" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.KioskHideHero">
                        <MudSwitch @bind-Value="_kioskHideHero" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Hide hero in kiosk" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.KioskLargeNowPlaying">
                        <MudSwitch @bind-Value="_kioskLargeNowPlaying" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Large Now Playing" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.KioskScreensaver">
                        <MudSwitch @bind-Value="_kioskScreensaver" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="Screensaver when idle" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.KioskScreensaverMinutes">
                        <MudNumericField @bind-Value="_kioskScreensaverMinutes" @bind-Value:after="ScheduleLivePreviewNow" Label="Screensaver after (min)" Variant="Variant.Outlined" Min="1" Max="120" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.KioskRotateSeconds">
                        <MudNumericField @bind-Value="_kioskRotateSeconds" @bind-Value:after="ScheduleLivePreviewNow" Label="Rotate every (sec)" Variant="Variant.Outlined" Min="5" Max="300" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.KioskRotate" Span2="true">
                        <MudSelect T="KioskRotateMode" @bind-Value="_kioskRotate" @bind-Value:after="ScheduleLivePreviewNow" Label="Panel rotation" Variant="Variant.Outlined">
                            <MudSelectItem Value="KioskRotateMode.Off">Show all panels</MudSelectItem>
                            <MudSelectItem Value="KioskRotateMode.Sequential">Rotate panels</MudSelectItem>
                            <MudSelectItem Value="KioskRotateMode.NowPlayingOnly">Now Playing only</MudSelectItem>
                        </MudSelect>
                    </SettingField>
                </div>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Services" Icon="@Icons.Material.Filled.ToggleOn">
            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-section-title">Enabled services</div>
                <SettingSectionHelp Text="@SettingsHelpTexts.ServicesEnabled" />
                <div class="settings-grid-2">
                    @foreach (var cred in _credentialStatuses)
                    {
                        <SettingField Text="@SettingsHelpTexts.ServiceEnabled(cred.Label)">
                            <MudSwitch @bind-Value="_serviceEnabled[cred.Key]" @bind-Value:after="ScheduleLivePreviewNow" Color="Color.Primary" Label="@cred.Label" Dense="true" />
                        </SettingField>
                    }
                </div>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="API keys" Icon="@Icons.Material.Filled.Key">
            @if (SelectedCredential is { } cred)
            {
                <MudPaper Class="settings-section compact" Elevation="0">
                    <SettingField Text="@SettingsHelpTexts.ApiServicePicker" Class="mb-3">
                        <MudSelect T="string" @bind-Value="_selectedServiceKey" Label="Service" Variant="Variant.Outlined">
                            @foreach (var option in _credentialStatuses)
                            {
                                <MudSelectItem Value="@option.Key">@option.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </SettingField>
                    <div class="credential-head mb-2">
                        <MudText Typo="Typo.subtitle1">@cred.Label</MudText>
                        <div class="credential-head-actions">
                            <MudChip T="string" Size="Size.Small" Color="@(cred.Configured ? Color.Success : Color.Default)" Variant="Variant.Outlined">
                                @(cred.Configured ? "Configured" : "Not set")
                            </MudChip>
                            <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => TestConnectionAsync(cred.Key))" Disabled="@_testing.Contains(cred.Key)">
                                @(_testing.Contains(cred.Key) ? "Testing…" : "Test")
                            </MudButton>
                        </div>
                    </div>
                    <MudText Typo="Typo.caption" Class="muted mb-2">@cred.Instructions</MudText>
                    @if (!string.IsNullOrWhiteSpace(cred.HelpUrl))
                    {
                        <MudLink Href="@cred.HelpUrl" Target="_blank" Class="mb-2 d-block">Open @cred.Label</MudLink>
                    }
                    <SettingField Text="@SettingsHelpTexts.ApiUrl" Class="mb-2">
                        <MudTextField @bind-Value="_urlInputs[cred.Key]"
                                      @bind-Value:after="ScheduleLivePreviewDebounced"
                                      Label="URL"
                                      Variant="Variant.Outlined"
                                      Disabled="@(cred.Key == "trakt")"
                                      Placeholder="@(cred.Key == "trakt" ? "Not required for Trakt" : (cred.CurrentUrl ?? "https://service.example.com"))" />
                    </SettingField>
                    <SettingField Text="@SettingsHelpTexts.ApiKey">
                        <MudTextField @bind-Value="_credentialInputs[cred.Key]"
                                      @bind-Value:after="ScheduleLivePreviewDebounced"
                                      Label="@(cred.Key == "trakt" ? "Client ID" : "API key / token")"
                                      Variant="Variant.Outlined"
                                      Placeholder="Leave blank to use saved key"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Filled.Visibility"
                                      OnAdornmentClick="@(() => ToggleReveal(cred.Key))"
                                      InputType="@RevealType(cred.Key)" />
                    </SettingField>
                    @if (cred.Key == "trakt")
                    {
                        <SettingField Text="Trakt Client Secret from your OAuth application.">
                            <MudTextField @bind-Value="_traktClientSecretInput"
                                          @bind-Value:after="ScheduleLivePreviewDebounced"
                                          Label="Client Secret"
                                          Variant="Variant.Outlined"
                                          Placeholder="Leave blank to keep saved secret"
                                          InputType="InputType.Password" />
                        </SettingField>
                    }
                </MudPaper>
            }
        </MudTabPanel>

        <MudTabPanel Text="Diagnostics" Icon="@Icons.Material.Filled.BugReport">
            <MudPaper Class="settings-section compact" Elevation="0">
                <div class="settings-section-title">Logging</div>
                <SettingField Text="@SettingsHelpTexts.LogLevel">
                    <MudSelect T="string" Value="_logLevel" ValueChanged="OnLogLevelChanged"
                               Label="Log level" Variant="Variant.Outlined" Dense="true">
                        <MudSelectItem T="string" Value="@("default")">Server default</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Trace")">Trace (very verbose)</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Debug")">Debug</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Information")">Information</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Warning")">Warning</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Error")">Error</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Critical")">Critical</MudSelectItem>
                        <MudSelectItem T="string" Value="@("None")">None (off)</MudSelectItem>
                    </MudSelect>
                </SettingField>
                <MudText Typo="Typo.caption" Class="muted mt-2 d-block">
                    View logs with <code>docker logs arrdash</code> (or the Unraid container log viewer).
                </MudText>
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
    </CascadingValue>
</MudContainer>

@code {
    private ThemePreference _theme = ThemePreference.System;
    private LayoutDensity _density = LayoutDensity.Comfortable;
    private BorderRadiusStyle _borderRadius = BorderRadiusStyle.Rounded;
    private string _primaryColor = AppearanceColorPresets.DefaultAccent;
    private string _lightTextColor = AppearanceColorPresets.DefaultLightText;
    private string _darkTextColor = AppearanceColorPresets.DefaultDarkText;
    private string _lightBackgroundColor = AppearanceColorPresets.DefaultLightBackground;
    private string _darkBackgroundColor = AppearanceColorPresets.DefaultDarkBackground;
    private BackgroundStyle _backgroundStyle = BackgroundStyle.Gradient;
    private string _brandMark = "A";
    private string _dashboardTitle = "";
    private string _dashboardSubtitle = "";
    private bool _hideHeroStrip;
    private PosterSize _posterSize = PosterSize.Medium;
    private PosterPlacement _posterPlacement = PosterPlacement.Left;
    private bool _showQuality = true;
    private bool _showEpisodeBadges = true;
    private bool _showMissingEpisodes = true;
    private bool _showSyncNotes = true;
    private int _defaultRecentLimit = 20;
    private RecentWindowMode _recentWindowMode = RecentWindowMode.ItemCount;
    private int _recentDays = 30;
    private AudiobookSourceMode _audiobookSource = AudiobookSourceMode.Merge;
    private TimeDisplayFormat _timeFormat = TimeDisplayFormat.Relative;
    private bool _showPlexSessions = true;
    private bool _showEmbySessions = true;
    private bool _showJellyfinSessions = true;
    private bool _hideIdleSessions;
    private bool _showPlexWatchStats = true;
    private bool _showEmbyWatchStats = true;
    private bool _showJellyfinWatchStats = true;
    private bool _showCombinedWatchStats = true;
    private bool _watchStatsSyncEnabled = true;
    private bool _watchStatsSyncPlex = true;
    private bool _watchStatsSyncEmby = true;
    private bool _watchStatsSyncJellyfin = true;
    private int _watchStatsRetentionDays;
    private int _watchStatsBackfillDays;
    private int _watchStatsSyncIntervalMinutes;
    private int _watchStatsTopLimit = 10;
    private string _watchStatsAliasesText = "";
    private readonly HashSet<string> _excludedLibraryKeys = new(StringComparer.OrdinalIgnoreCase);
    private List<WatchStatsLibraryInfo> _libraryCatalog = [];
    private bool _librariesLoading;
    private List<ArrDash.Data.Entities.TraktAccountEntity> _traktAccounts = [];
    private bool _traktBusy;
    private string? _traktConnectHint;
    private string? _traktPendingUserCode;
    private string? _traktStatus;
    private string _traktClientSecretInput = "";
    private bool _showServerMetrics = true;
    private string _metricsHostLabel = "";
    private string _metricsDiskPath = "";
    private int _metricsPollIntervalSeconds;
    private int _metricsGraphWindowMinutes;
    private int _networkPieChartSize = 160;
    private NetworkPieStyle _networkPieStyle = NetworkPieStyle.Soft;
    private bool _networkPieShowSliceLabels;
    private bool _networkLegendShowPercent;
    private bool _networkLegendShowRate;
    private bool _networkLegendShowCpu;
    private bool _enableClickThrough = true;
    private bool _deepLinkClickThrough = true;
    private ExternalLinkTarget _externalLinkTarget = ExternalLinkTarget.NewTab;
    private MissingEpisodeClickAction _missingEpisodeClickAction = MissingEpisodeClickAction.SearchOnly;
    private bool _friendlyQualityLabels = true;
    private int _pollIntervalSeconds;
    private bool _manualRefreshOnly;
    private StatusBarMode _statusBarMode = StatusBarMode.All;
    private StatusBarAlignment _statusBarAlignment = StatusBarAlignment.Left;
    private StartupPage _startupPage = StartupPage.Dashboard;
    private bool _autoKioskOnLoad;
    private bool _kioskHideHero = true;
    private bool _kioskLargeNowPlaying;
    private bool _kioskScreensaver;
    private int _kioskScreensaverMinutes = 5;
    private KioskRotateMode _kioskRotate = KioskRotateMode.Off;
    private int _kioskRotateSeconds = 30;
    private List<string> _panelOrder = [];
    private Dictionary<string, int?> _recentLimits = new();
    private Dictionary<string, bool> _panelHidden = new();
    private Dictionary<string, PanelViewMode> _panelViewModes = new();
    private Dictionary<string, string> _panelAccentColors = new();
    private Dictionary<string, bool> _serviceEnabled = new();
    private Dictionary<string, string> _credentialInputs = new();
    private Dictionary<string, string> _urlInputs = new();
    private HashSet<string> _revealedKeys = new();
    private HashSet<string> _testing = new();
    private IReadOnlyList<CredentialStatus> _credentialStatuses = [];
    private string _selectedServiceKey = "sonarr";
    private bool _saving;
    private bool _showSettingsHelp;
    private bool _systemIsDark;
    private System.Threading.Timer? _debounceTimer;

    private CredentialStatus? SelectedCredential =>
        _credentialStatuses.FirstOrDefault(c => c.Key == _selectedServiceKey)
        ?? _credentialStatuses.FirstOrDefault();

    private RenderFragment RenderTextColorField(bool isLightMode) => __builder =>
    {
        var value = isLightMode ? _lightTextColor : _darkTextColor;
        var presets = isLightMode ? AppearanceColorPresets.LightText : AppearanceColorPresets.DarkText;
        var defaultColor = isLightMode ? AppearanceColorPresets.DefaultLightText : AppearanceColorPresets.DefaultDarkText;
        var label = isLightMode ? "Light mode text" : "Dark mode text";
        var hint = isLightMode
            ? "Dark colours for light backgrounds."
            : "Light colours for dark backgrounds.";
        var previewBg = isLightMode ? "#f4f6fb" : "#0b1020";

        <PresetColorField Label="@label"
                          Hint="@hint"
                          Value="@value"
                          ValueChanged="@(color => OnTextColorChanged(isLightMode, color))"
                          Presets="@presets"
                          DefaultColor="@defaultColor">
            <Preview>
                <div class="appearance-text-preview" style="@($"color:{value};background:{previewBg}")">
                    <span class="appearance-text-preview-heading">Sample heading</span>
                    <span class="appearance-text-preview-body">Body text</span>
                </div>
            </Preview>
        </PresetColorField>;
    };

    private RenderFragment RenderBackgroundColorField(bool isLightMode) => __builder =>
    {
        var value = isLightMode ? _lightBackgroundColor : _darkBackgroundColor;
        var presets = isLightMode ? AppearanceColorPresets.LightBackground : AppearanceColorPresets.DarkBackground;
        var defaultColor = isLightMode ? AppearanceColorPresets.DefaultLightBackground : AppearanceColorPresets.DefaultDarkBackground;
        var label = isLightMode ? "Light background" : "Dark background";
        var hint = isLightMode
            ? "Page background in light mode."
            : "Page background in dark mode.";

        <PresetColorField Label="@label"
                          Hint="@hint"
                          Value="@value"
                          ValueChanged="@(color => OnBackgroundColorChanged(isLightMode, color))"
                          Presets="@presets"
                          DefaultColor="@defaultColor">
            <Preview>
                <div class="appearance-bg-preview" style="@($"background:{value}")"></div>
            </Preview>
        </PresetColorField>;
    };

    protected override void OnInitialized()
    {
        RefreshCredentialStatuses();
        LoadFromPrefs();
        Prefs.Changed += OnPrefsChanged;
        Secrets.Changed += OnSecretsChanged;
        ThemeService.OnChange += OnSystemThemeChanged;
    }

