@using ArrDash.Models
@using ArrDash.Services

<section class="watch-stats-mini-section">
    <div class="watch-stats-section-title">@Title</div>
    @if (Rows.Count == 0)
    {
        <div class="watch-stats-empty">No data</div>
    }
    else
    {
        <div class="watch-stats-list">
            @{
                var rank = 0;
            }
            @foreach (var row in Rows.Take(MaxItems))
            {
                rank++;
                <div class="watch-stats-row @(ShowRank ? "has-rank" : "") @(OnRowClick.HasDelegate ? "is-clickable" : "")"
                     role="@(OnRowClick.HasDelegate ? "button" : null)"
                     tabindex="@(OnRowClick.HasDelegate ? "0" : null)"
                     @onclick="@(() => RowClicked(row))"
                     @onkeydown="@(e => OnRowKeyDown(e, row))">
                    @if (ShowRank)
                    {
                        <div class="watch-stats-rank">@rank</div>
                    }
                    @if (ShowThumb)
                    {
                        <div class="watch-stats-thumb-slot">
                            @{
                                var (primary, secondary) = ThumbSources(row);
                            }
                            @if (primary is not null)
                            {
                                @* Dead/expired posters (deleted or re-matched server-side) fail client-side;
                                   arrdashThumb tries the fallback URL, then the icon tile. *@
                                <img class="watch-stats-thumb @(UseAvatar ? "is-avatar" : "")" src="@primary" alt="" loading="lazy"
                                     data-fallback="@secondary"
                                     onerror="arrdashThumb.onError(this)" onload="arrdashThumb.onLoad(this)" />
                                <span class="watch-stats-thumb-fallback watch-stats-thumb-fallback-hidden @(UseAvatar ? "is-avatar" : "")">
                                    <MudIcon Icon="@(UseAvatar ? Icons.Material.Filled.Person : Icons.Material.Filled.Movie)" Size="Size.Small" />
                                </span>
                            }
                            else
                            {
                                <span class="watch-stats-thumb-fallback @(UseAvatar ? "is-avatar" : "")">
                                    <MudIcon Icon="@(UseAvatar ? Icons.Material.Filled.Person : Icons.Material.Filled.Movie)" Size="Size.Small" />
                                </span>
                            }
                        </div>
                    }
                    <div class="watch-stats-row-body">
                        <div class="watch-stats-row-title" title="@row.Title">@row.Title</div>
                        @if (!string.IsNullOrWhiteSpace(row.Subtitle))
                        {
                            <div class="watch-stats-row-sub" title="@row.Subtitle">@row.Subtitle</div>
                        }
                    </div>
                    <div class="watch-stats-row-meta">@Meta(row)</div>
                </div>
            }
        </div>
    }
</section>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public IReadOnlyList<WatchStatRow> Rows { get; set; } = [];
    [Parameter] public bool ShowThumb { get; set; }
    [Parameter] public bool UseAvatar { get; set; }
    [Parameter] public bool ShowRank { get; set; }
    [Parameter] public bool ShowRelativeTime { get; set; }
    [Parameter] public int MaxItems { get; set; } = 3;
    [Parameter] public EventCallback<WatchStatRow> OnRowClick { get; set; }

    private static (string? Primary, string? Secondary) ThumbSources(WatchStatRow row) =>
        !string.IsNullOrWhiteSpace(row.ThumbUrl)
            ? (row.ThumbUrl, string.IsNullOrWhiteSpace(row.FallbackThumbUrl) ? null : row.FallbackThumbUrl)
            : !string.IsNullOrWhiteSpace(row.FallbackThumbUrl)
                ? (row.FallbackThumbUrl, null)
                : (null, null);

    private string Meta(WatchStatRow row) =>
        ShowRelativeTime && row.LastPlayedAtUtc is { } at
            ? TimeDisplayHelper.FormatRelative(at)
            : $"{row.Hours:0.#}h";

    private Task RowClicked(WatchStatRow row) =>
        OnRowClick.HasDelegate ? OnRowClick.InvokeAsync(row) : Task.CompletedTask;

    private Task OnRowKeyDown(KeyboardEventArgs e, WatchStatRow row) =>
        e.Key is "Enter" or " " ? RowClicked(row) : Task.CompletedTask;
}
