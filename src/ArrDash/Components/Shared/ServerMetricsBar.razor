    protected override void OnParametersSet()
    {
        if (Metrics is not null)
            _liveMetrics = Metrics;

        _displayCpu ??= Metrics?.CpuPercent ?? LatestHistoryPercent();
        RebuildCpuChart();
    }

    private double? LatestHistoryPercent() =>
        CpuHistory.GetSamples(TimeSpan.FromMinutes(1)).LastOrDefault()?.Percent;

    private async Task PollLoopAsync()
    {
        PollTick();

        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(_pollIntervalSeconds));
        try
        {
            while (await timer.WaitForNextTickAsync(_pollCts.Token))
            {
                PollTick();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void PollTick()
    {
        _coreUsage = HostMetrics.ReadPerCoreUsage();

        var metrics = HostMetrics.Read();
        if (metrics is null)
            return;

        _liveMetrics = metrics;

        if (metrics.CpuPercent is double cpu)
            _displayCpu = cpu;

        if (metrics.IoWaitPercent is double ioWait)
            _displayIoWait = ioWait;

        RebuildCpuChart();
    }

    private async Task OnGraphHover(MouseEventArgs e)
    {
        var pos = await Js.InvokeAsync<PlotPointer?>("arrdashMetrics.pointerInElement", _plotRef, e.ClientX);
        if (pos is null || pos.Width <= 0)
            return;

        UpdateHover(pos.X, pos.Width);
        await InvokeAsync(StateHasChanged);
    }

    private void OnGraphLeave()
    {
        _hover = null;
    }

    private void UpdateHover(double pixelX, double plotWidth)
    {
        var ratio = Math.Clamp(pixelX / plotWidth, 0, 1);
        var windowEnd = DateTimeOffset.UtcNow;
        var windowStart = windowEnd.AddMinutes(-_graphWindowMinutes);
        var span = Math.Max((windowEnd - windowStart).TotalSeconds, 1);
        var at = windowStart.AddSeconds(ratio * span);
        var points = BuildInterpolationSamples(windowEnd);
        var percent = InterpolateAt(points, at, s => s.Percent, _displayCpu ?? 0);
        var ioWait = InterpolateAt(points, at, s => s.IoWaitPercent, _displayIoWait ?? 0);
        var chartX = PlotLeft + ratio * (PlotRight - PlotLeft);

        _hover = new HoverState(
            percent,
            ioWait,
            at.ToLocalTime().ToString("HH:mm:ss"),
            pixelX,
            chartX,
            YForPercent(percent));
    }

    private static double InterpolateAt(List<CpuSample> points, DateTimeOffset at, Func<CpuSample, double> selector, double fallback)
    {
        if (points.Count == 0)
            return fallback;

        if (at <= points[0].At)
            return selector(points[0]);

        if (at >= points[^1].At)
            return selector(points[^1]);

        for (var i = 1; i < points.Count; i++)
        {
            var prev = points[i - 1];
            var next = points[i];
            if (at > next.At)
                continue;

            var span = (next.At - prev.At).TotalSeconds;
            if (span <= 0)
                return selector(next);

            var ratio = (at - prev.At).TotalSeconds / span;
            return selector(prev) + (selector(next) - selector(prev)) * ratio;
        }

        return selector(points[^1]);
    }

    private List<CpuSample> BuildInterpolationSamples(DateTimeOffset windowEnd)
    {
        var points = CpuHistory.GetSamples(TimeSpan.FromMinutes(_graphWindowMinutes)).ToList();

        if (_displayCpu is double live)
        {
            var liveIoWait = _displayIoWait ?? points.LastOrDefault()?.IoWaitPercent ?? 0;
            if (points.Count == 0 || points[^1].At < windowEnd.AddSeconds(-1))
                points.Add(new CpuSample(windowEnd, live, liveIoWait));
            else
                points[^1] = points[^1] with { At = windowEnd, Percent = live, IoWaitPercent = liveIoWait };
        }

        return points;
    }

    private void RebuildCpuChart()
    {
        var windowEnd = DateTimeOffset.UtcNow;
        var windowStart = windowEnd.AddMinutes(-_graphWindowMinutes);
        _windowStartLabel = windowStart.ToLocalTime().ToString(_graphWindowMinutes >= 24 * 60 ? "dd MMM HH:mm" : "HH:mm");

        var historySamples = CpuHistory.GetSamples(TimeSpan.FromMinutes(_graphWindowMinutes));

        var points = BuildChartPoints(historySamples, windowStart, windowEnd, s => s.Percent, _displayCpu);
        if (points.Count == 0)
        {
            _linePath = "";
            _areaPath = "";
            _ioWaitLinePath = "";
            _latestPoint = null;
            return;
        }

        _linePath = "M " + string.Join(" L ", points.Select(p => Form(p.X, p.Y)));
        var baseline = YForPercent(0);
        _areaPath = _linePath +
                    $" L {Form(points[^1].X, baseline)} L {Form(points[0].X, baseline)} Z";
        _latestPoint = points[^1];

        var ioPoints = BuildChartPoints(historySamples, windowStart, windowEnd, s => s.IoWaitPercent, _displayIoWait);
        _ioWaitLinePath = ioPoints.Count > 0 ? "M " + string.Join(" L ", ioPoints.Select(p => Form(p.X, p.Y))) : "";
    }

    private List<PlotPoint> BuildChartPoints(
        IReadOnlyList<CpuSample> historySamples, DateTimeOffset windowStart, DateTimeOffset windowEnd,
        Func<CpuSample, double> selector, double? displayValue)
    {
        var points = historySamples
            .Where(s => s.At <= windowEnd)
            .OrderBy(s => s.At)
            .Select(s => new PlotPoint(XForTime(s.At, windowStart, windowEnd), YForPercent(selector(s))))
            .ToList();

        if (points.Count == 0 && displayValue is double current)
        {
            var y = YForPercent(current);
            points.Add(new PlotPoint(PlotLeft, y));
            points.Add(new PlotPoint(PlotRight, y));
        }
        else if (points.Count > 0)
        {
            var liveValue = displayValue ?? selector(historySamples[^1]);
            var liveY = YForPercent(liveValue);

            if (points[^1].X >= PlotRight - 0.5)
                points[^1] = new PlotPoint(PlotRight, liveY);
            else
                points.Add(new PlotPoint(PlotRight, liveY));
        }

        return points;
    }

    private RenderFragment RingSvg(double usedPercent) => __builder =>
    {
        var offset = RingCircumference * (1 - usedPercent / 100d);
        __builder.OpenElement(0, "svg");
        __builder.AddAttribute(1, "viewBox", "0 0 100 100");
        __builder.AddAttribute(2, "class", "usage-ring-svg");
        __builder.OpenElement(3, "circle");
        __builder.AddAttribute(4, "cx", "50");
        __builder.AddAttribute(5, "cy", "50");
        __builder.AddAttribute(6, "r", RingRadius);
        __builder.AddAttribute(7, "class", "usage-ring-track");
        __builder.CloseElement();
        __builder.OpenElement(8, "circle");
        __builder.AddAttribute(9, "cx", "50");
        __builder.AddAttribute(10, "cy", "50");
        __builder.AddAttribute(11, "r", RingRadius);
        __builder.AddAttribute(12, "class", "usage-ring-value");
        __builder.AddAttribute(13, "stroke-dasharray", RingCircumference.ToString(CultureInfo.InvariantCulture));
        __builder.AddAttribute(14, "stroke-dashoffset", offset.ToString(CultureInfo.InvariantCulture));
        __builder.AddAttribute(15, "transform", "rotate(-90 50 50)");
        __builder.CloseElement();
        __builder.OpenElement(16, "text");
        __builder.AddAttribute(17, "x", "50");
        __builder.AddAttribute(18, "y", "50");
        __builder.AddAttribute(19, "class", "usage-ring-center");
        __builder.AddContent(20, $"{usedPercent:0.#}%");
        __builder.CloseElement();
        __builder.CloseElement();
    };

    private static string RingStyle(double usedPercent) => $"--ring-color:{UsageColor(usedPercent)}";

    private static string RingStyle(string color) => $"--ring-color:{color}";

    private static double XForTime(DateTimeOffset at, DateTimeOffset start, DateTimeOffset end)
    {
        var span = Math.Max((end - start).TotalSeconds, 1);
        var ratio = Math.Clamp((at - start).TotalSeconds / span, 0, 1);
        return PlotLeft + ratio * (PlotRight - PlotLeft);
    }

    private static double YForPercent(double percent)
    {
        var ratio = Math.Clamp(percent, 0, 100) / 100d;
        return PlotBottom - ratio * (PlotBottom - PlotTop);
    }

    private static string Form(double x, double y) =>
        $"{x.ToString("0.##", CultureInfo.InvariantCulture)},{y.ToString("0.##", CultureInfo.InvariantCulture)}";

    private static string UsageColor(double percent) => percent switch
    {
        >= 90 => "#ef4444",
        >= 75 => "#f59e0b",
        _ => "#6366f1"
    };

    public void Dispose()
    {
        Prefs.Changed -= OnPrefsChanged;
        _pollCts.Cancel();
        _scrollTimer?.Dispose();
    }

    public ValueTask DisposeAsync()
    {
        Dispose();
        return ValueTask.CompletedTask;
    }

    private sealed record PlotPoint(double X, double Y);
    private sealed record HoverState(double Percent, double IoWaitPercent, string TimeLabel, double PixelX, double ChartX, double ChartY);
    private sealed record PlotPointer(double X, double Width);
}
