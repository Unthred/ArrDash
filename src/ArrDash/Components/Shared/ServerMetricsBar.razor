@using ArrDash.Models
@using ArrDash.Services
@using System.Globalization
@using Microsoft.JSInterop
@implements IDisposable
@implements IAsyncDisposable
@inject HostSystemMetricsService HostMetrics
@inject CpuHistoryService CpuHistory
@inject UnraidActivityService UnraidActivityService
@inject LayoutPreferencesService Prefs
@inject IJSRuntime Js

<MudPaper Class="@ShellClass" Elevation="0">
        <ServiceStatusBar Services="Services"
                          SampledAt="SampledAt"
                          Mode="Prefs.Current.StatusBarMode"
                          Alignment="Prefs.Current.StatusBarAlignment"
                          SelectedServiceKey="@SelectedServiceKey"
                          SelectedServiceKeyChanged="@SelectedServiceKeyChanged"
                          ShowNetworkPills="true"
                          NetworkDetailOpen="_networkDetailOpen"
                          OnToggleNetworkDetail="ToggleNetworkDetail" />

        <div class="server-metrics-head panel-header-rollup" title="Double-click to expand or collapse" @ondblclick="ToggleRollup">
            <div class="server-metrics-title-wrap">
                <MudIcon Icon="@Icons.Material.Filled.Memory" Size="Size.Small" />
                <span class="server-metrics-label">@EffectiveMetrics.Label</span>
            </div>

            @if (RolledUp)
            {
                <div class="rollup-summary server-metrics-rollup">
                    <div class="rollup-metrics-group">
                        <CpuSparkline Samples="SparkSamples" />
                        <span class="rollup-stat rollup-stat-cpu">CPU @CpuHeadline()</span>
                    </div>
                    <MiniUsageRing Label="Mem"
                                   Detail="@MemoryDetailLabel()"
                                   Percent="EffectiveMetrics.MemoryUsedPercent"
                                   Color="@UsageColor(EffectiveMetrics.MemoryUsedPercent)" />
                    <MiniUsageRing Label="Disk"
                                   Detail="@DiskDetailLabel()"
                                   Percent="EffectiveMetrics.DiskUsedPercent"
                                   Color="@UsageColor(EffectiveMetrics.DiskUsedPercent)" />
                    @if (ShowUnraidActivitySections)
                    {
                        <MiniUsageRing Label="@ParityRollupLabel()"
                                       Detail="@ParityRollupDetail()"
                                       Percent="@(_unraidActivity?.ParityCheckPercent ?? 0)"
                                       Color="#f59e0b" />
                    }
                    <MiniUsageRing Label="CPU°"
                                   Detail="@CpuTempDetailLabel()"
                                   Percent="@CpuTempRingPercent()"
                                   Color="@UsageColor(CpuTempRingPercent())" />
                    <span class="rollup-stat" title="@DiskRollupTooltip()">Disks @DiskRollupLabel()</span>
                    <span class="rollup-stat" title="@TopContainerRollupTooltip()">Top @TopContainerRollupLabel()</span>
                    <span class="rollup-stat">Up @UptimeRollupLabel()</span>
                </div>
            }
        </div>

        @if (!RolledUp)
        {
        <div class="server-metrics-body">
            <div class="cpu-live-graph metrics-column metrics-column-cpu">
                <div class="cpu-live-head">
                    <span class="cpu-live-title">CPU usage</span>
                    <div class="cpu-live-window-toggle">
                        @foreach (var minutes in GraphWindowChoices)
                        {
                            <button type="button"
                                    class="cpu-live-window-btn @(_graphWindowMinutes == minutes ? "cpu-live-window-btn-active" : "")"
                                    @onclick="@(() => SelectGraphWindow(minutes))">@minutes m</button>
                        }
                    </div>
                    @if (_displayCpu is not null || HostMetricsLoading)
                    {
                        <span class="cpu-live-now">@CpuHeadline()</span>
                    }
                </div>
                <div class="cpu-live-iowait-row @(_displayIoWait is double clickableIoWait && clickableIoWait >= 2 ? "cpu-live-iowait-row-clickable" : "")"
                     title="System-wide CPU iowait — time cores spent blocked waiting for any storage (array, cache, FUSE). Not the same as how full a disk is. Click to inspect per-disk I/O."
                     @onclick="@(async () => { if (_displayIoWait is double iw && iw >= 2) await ToggleDetail("disks"); })">
                    @if (_displayIoWait is double iowait && iowait >= 2)
                    {
                        <span>Waiting on disk @($"{iowait:0.#}%")</span>
                    }
                </div>
                <div class="cpu-live-chart-row">
                    <div class="cpu-live-axis-y" aria-hidden="true">
                        <span>100%</span>
                        <span>50%</span>
                        <span>0%</span>
                    </div>
                    <div class="cpu-live-plot" @ref="_plotRef">
                        <div class="cpu-live-hitarea"
                             @onmousemove="OnGraphHover"
                             @onmouseleave="OnGraphLeave"></div>
                        <svg viewBox="0 0 @ChartWidth @ChartHeight" preserveAspectRatio="none" class="cpu-live-svg" aria-label="CPU usage over time">
                            <defs>
                                <linearGradient id="cpuAreaFill" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="var(--cpu-line)" stop-opacity="0.35" />
                                    <stop offset="100%" stop-color="var(--cpu-line)" stop-opacity="0.02" />
                                </linearGradient>
                            </defs>
                            @foreach (var y in _gridLines)
                            {
                                <line x1="@PlotLeft" y1="@y" x2="@PlotRight" y2="@y" class="cpu-grid-line" />
                            }
                            @if (!string.IsNullOrEmpty(_areaPath))
                            {
                                <path d="@_areaPath" class="cpu-area" />
                            }
                            @if (!string.IsNullOrEmpty(_linePath))
                            {
                                <path d="@_linePath" class="cpu-line" />
                            }
                            @if (!string.IsNullOrEmpty(_ioWaitLinePath))
                            {
                                <path d="@_ioWaitLinePath" class="cpu-iowait-line" />
                            }
                            @if (_hover is { } hover)
                            {
                                <line x1="@hover.ChartX" y1="@PlotTop" x2="@hover.ChartX" y2="@PlotBottom" class="cpu-hover-line" />
                                <circle cx="@hover.ChartX" cy="@hover.ChartY" r="3.5" class="cpu-dot cpu-hover-dot" />
                            }
                            else if (_latestPoint is { } point)
                            {
                                <circle cx="@point.X" cy="@point.Y" r="3" class="cpu-dot" />
                            }
                        </svg>
                        @if (_hover is { } tip)
                        {
                            <div class="cpu-graph-tooltip" style="left: @(tip.PixelX.ToString(CultureInfo.InvariantCulture))px">
                                <span class="cpu-graph-tooltip-value">@($"{tip.Percent:0.#}%")</span>
                                @if (tip.IoWaitPercent >= 2)
                                {
                                    <span class="cpu-graph-tooltip-value cpu-graph-tooltip-iowait">@($"IO {tip.IoWaitPercent:0.#}%")</span>
                                }
                                <span class="cpu-graph-tooltip-time">@tip.TimeLabel</span>
                            </div>
                        }
                    </div>
                </div>
                <div class="cpu-live-axis-x">
                    <span>@_windowStartLabel</span>
                    <span>now</span>
                </div>
            </div>

            <div class="metrics-column-splitter" aria-hidden="true"></div>

            <div class="server-metrics-scroll">
            @if (_selectedDetail is not null)
            {
                <div class="metrics-detail-panel">
                    <div class="metrics-detail-head">
                        <span class="metrics-detail-title">@DetailTitle(_selectedDetail)</span>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => ToggleDetail(_selectedDetail))" />
                    </div>
                    <div class="metrics-detail-body">
                        @if (_selectedDetail == "disks")
                        {
                            <div class="metrics-detail-hint">@DiskDetailIntro()</div>
                        }
                        @if (_selectedDetail == "stuck")
                        {
                            <div class="metrics-detail-hint">@StuckDetailIntro()</div>
                        }
                        @if (_unraidActivity is null)
                        {
                            <div class="metrics-detail-empty">@LoadingLabel</div>
                        }
                        else
                        {
                        @switch (_selectedDetail)
                        {
                            case "memory":
                                if (_unraidActivity!.TopContainers.Count == 0)
                                {
                                    <div class="metrics-detail-empty">No container data</div>
                                }
                                foreach (var container in TopByMemory(_unraidActivity))
                                {
                                    <div class="metrics-detail-row">
                                        <span class="metrics-detail-row-label">@container.Name</span>
                                        <div class="metrics-detail-bar-track">
                                            <div class="metrics-detail-bar" style="width:@(Math.Clamp(container.MemoryUsedPercent, 0, 100).ToString("0.#", CultureInfo.InvariantCulture))%; background:#22c55e"></div>
                                        </div>
                                        <span class="metrics-detail-row-value">@container.MemoryUsedPercent.ToString("0.#")%</span>
                                    </div>
                                }
                                break;
                            case "top-cpu":
                                if (_unraidActivity!.TopContainers.Count == 0)
                                {
                                    <div class="metrics-detail-empty">No container data</div>
                                }
                                foreach (var container in TopByCpu(_unraidActivity))
                                {
                                    <div class="metrics-detail-row" title="@CoreUsageTooltip(container)">
                                        <span class="metrics-detail-row-label">@container.Name</span>
                                        <div class="metrics-detail-bar-track">
                                            <div class="metrics-detail-bar" style="width:@(Math.Clamp(container.CpuPercent, 0, 100).ToString("0.#", CultureInfo.InvariantCulture))%; background:#f5c518"></div>
                                        </div>
                                        <span class="metrics-detail-row-value">@container.CpuPercent.ToString("0.#")%</span>
                                    </div>
                                }
                                break;
                            case "cpu-temp":
                                if (_coreUsage.Count == 0)
                                {
                                    <div class="metrics-detail-empty">Collecting core usage…</div>
                                }
                                foreach (var coreId in MergedCoreIds(_unraidActivity!))
                                {
                                    <div class="metrics-detail-row">
                                        <span class="metrics-detail-row-label">Core @coreId</span>
                                        <span class="metrics-detail-row-value">@(CoreTempFor(_unraidActivity!, coreId) is double ct ? $"{ct:0.#}°C" : "—")</span>
                                        <div class="metrics-detail-bar-track">
                                            @if (CoreUsageFor(coreId) is double pct)
                                            {
                                                <div class="metrics-detail-bar" style="width:@(Math.Clamp(pct, 0, 100).ToString("0.#", CultureInfo.InvariantCulture))%; background:@CoreBarColor(pct)"></div>
                                            }
                                        </div>
                                        <span class="metrics-detail-row-value">@(CoreUsageFor(coreId) is double p ? $"{p:0.#}%" : "—")</span>
                                    </div>
                                }
                                break;
                            case "disks":
                                if (_unraidActivity!.DiskHealth is not { AllDisks.Count: > 0 })
                                {
                                    <div class="metrics-detail-empty">No disk data</div>
                                }
                                else
                                {
                                    foreach (var disk in _unraidActivity.DiskHealth.AllDisks.OrderByDescending(d => d.BusyPercent ?? -1))
                                    {
                                        <div class="metrics-detail-disk">
                                            <div class="metrics-detail-disk-line">
                                                <span class="metrics-detail-disk-name @(disk.BusyPercent is double busyName && busyName >= 50 ? "metrics-detail-disk-name-busy" : "")">@disk.Name</span>
                                                <span class="metrics-detail-disk-capacity-label">Capacity</span>
                                                <div class="metrics-detail-bar-track">
                                                    @if (disk.SizeBytes is long size and > 0 && disk.UsedBytes is long used)
                                                    {
                                                        <div class="metrics-detail-bar" style="width:@((used * 100.0 / size).ToString("0.#", CultureInfo.InvariantCulture))%; background:#35c5f4"></div>
                                                    }
                                                </div>
                                                <span class="metrics-detail-disk-fraction">@DiskUsageFraction(disk)</span>
                                            </div>
                                            <div class="metrics-detail-disk-meta">
                                                @DiskMetaLine(disk)
                                                <span class="metrics-detail-disk-busy"> · @DiskIoBusyLabel(disk)</span>
                                                @if (disk.NumErrors > 0)
                                                {
                                                    <span class="metrics-detail-disk-error"> · @disk.NumErrors errors</span>
                                                }
                                                @if (disk.Status is { } st && st != "DISK_OK")
                                                {
                                                    <span class="metrics-detail-disk-error"> · @st</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                                break;
                            case "stuck":
                                if (_unraidActivity!.StuckProcesses.Count == 0)
                                {
                                    <div class="metrics-detail-empty">Nothing is blocked on storage right now — that's good.</div>
                                }
                                foreach (var stuck in _unraidActivity.StuckProcesses)
                                {
                                    <div class="metrics-detail-stuck-row">
                                        <div class="metrics-detail-stuck-head">
                                            <span class="metrics-detail-stuck-kind @StuckKindClass(stuck.Kind)">@StuckProcessDisplay.KindLabel(stuck.Kind)</span>
                                            <span class="metrics-detail-stuck-severity">@StuckProcessDisplay.ExpectedSeverity(stuck.Kind)</span>
                                        </div>
                                        <div class="metrics-detail-stuck-copy">
                                            <span class="metrics-detail-stuck-name">@stuck.DisplayName</span>
                                            @if (ShowInnerProcessName(stuck))
                                            {
                                                <span class="metrics-detail-stuck-process">Process inside container: @stuck.ProcessName</span>
                                            }
                                            <span class="metrics-detail-stuck-meta">PID @stuck.Pid · @StuckProcessDisplay.KindGuidance(stuck.Kind)</span>
                                            @if (!string.IsNullOrWhiteSpace(stuck.CommandLine))
                                            {
                                                <span class="metrics-detail-stuck-cmd" title="@stuck.CommandLine">@stuck.CommandLine</span>
                                            }
                                        </div>
                                    </div>
                                }
                                break;
                        }
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="usage-stack metrics-column">
                    <div class="usage-row usage-row-clickable" style="@RingStyle(EffectiveMetrics.MemoryUsedPercent)" @onclick="@(() => ToggleDetail("memory"))">
                        @RingSvg(EffectiveMetrics.MemoryUsedPercent)
                        <div class="usage-row-copy">
                            <div class="usage-row-title">Memory</div>
                            <div class="usage-row-used">@MemoryUsedLabel()</div>
                            <div class="usage-row-total">@MemoryTotalLabel()</div>
                        </div>
                    </div>
                    <div class="usage-stack-divider" aria-hidden="true"></div>
                    <div class="usage-row @(ShowUnraidActivitySections ? "usage-row-clickable" : "")" style="@RingStyle(EffectiveMetrics.DiskUsedPercent)" @onclick="@(async () => { if (ShowUnraidActivitySections) await ToggleDetail("disks"); })">
                        @RingSvg(EffectiveMetrics.DiskUsedPercent)
                        <div class="usage-row-copy">
                            <div class="usage-row-title">Disk@(ShowUnraidActivitySections ? $" · {DiskRollupLabel()}" : "")</div>
                            <div class="usage-row-used">@DiskUsedLabel()</div>
                            <div class="usage-row-total">@DiskTotalLabel()</div>
                        </div>
                    </div>
                </div>

                <div class="metrics-column-splitter" aria-hidden="true"></div>

                <div class="usage-stack usage-stack-compact metrics-column">
                    <div class="usage-row usage-row-clickable" style="@CpuTempRingStyle()" @onclick="@(() => ToggleDetail("cpu-temp"))">
                        @if (_unraidActivity?.CpuTemperatureCelsius is double tempPercent)
                        {
                            @RingSvg(Math.Clamp(tempPercent / 90 * 100, 0, 100))
                        }
                        else
                        {
                            <div class="activity-icon-box activity-icon-box-idle">
                                <MudIcon Icon="@Icons.Material.Filled.Thermostat" Size="Size.Large" />
                            </div>
                        }
                        <div class="usage-row-copy">
                            <div class="usage-row-title">CPU</div>
                            <div class="usage-row-used">@CpuTempDetailLabel()</div>
                        </div>
                    </div>
                    <div class="usage-stack-divider" aria-hidden="true"></div>
                    <div class="usage-row usage-row-clickable" @onclick="@(() => ToggleDetail("top-cpu"))" title="@TopContainerRollupTooltip()">
                        <div class="activity-icon-box activity-icon-box-idle">
                            <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Large" />
                        </div>
                        <div class="usage-row-copy">
                            <div class="usage-row-title">Top CPU</div>
                            <div class="usage-row-used">@TopContainerRollupLabel()</div>
                        </div>
                    </div>
                </div>

                <div class="metrics-column-splitter" aria-hidden="true"></div>

                <div class="usage-stack usage-stack-compact metrics-column">
                    <div class="usage-row" title="@ContainerListTooltip(_unraidActivity?.RestartingContainers ?? EmptyContainerNames)">
                        <div class="activity-icon-box @((_unraidActivity?.RestartingContainers.Count ?? 0) > 0 ? "" : "activity-icon-box-idle")">
                            <MudIcon Icon="@Icons.Material.Filled.Autorenew" Size="Size.Large" Class="@((_unraidActivity?.RestartingContainers.Count ?? 0) > 0 ? "activity-icon-spin" : "")" />
                        </div>
                        <div class="usage-row-copy">
                            <div class="usage-row-title">Restarting</div>
                            <div class="usage-row-used">@RestartingLabel()</div>
                        </div>
                    </div>
                    <div class="usage-stack-divider" aria-hidden="true"></div>
                    <div class="usage-row" title="@ContainerListTooltip(_unraidActivity?.RecentlyUpdatedContainers ?? EmptyContainerNames)">
                        <div class="activity-icon-box @((_unraidActivity?.RecentlyUpdatedContainers.Count ?? 0) > 0 ? "activity-icon-box-updated" : "activity-icon-box-idle")">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" />
                        </div>
                        <div class="usage-row-copy">
                            <div class="usage-row-title">Updated</div>
                            <div class="usage-row-used">@UpdatedContainersLabel()</div>
                        </div>
                    </div>
                </div>

                @if (ShowUnraidActivitySections)
                {
                    <div class="metrics-column-splitter" aria-hidden="true"></div>

                    <div class="usage-stack usage-stack-compact metrics-column">
                        <div class="usage-row">
                            <div class="activity-icon-box @((_unraidActivity?.MoverRunning ?? false) ? "" : "activity-icon-box-idle")">
                                @if (_unraidActivity?.MoverRunning == true)
                                {
                                    <div class="mover-spinner" style="--tile-color:#818cf8"></div>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.DriveFileMove" Size="Size.Large" />
                                }
                            </div>
                            <div class="usage-row-copy">
                                <div class="usage-row-title">Mover</div>
                                <div class="usage-row-used">@MoverLabel()</div>
                            </div>
                        </div>
                        <div class="usage-stack-divider" aria-hidden="true"></div>
                        <div class="usage-row" style="@ParityRingStyle()">
                            @if (_unraidActivity is { ParityCheckRunning: true })
                            {
                                @RingSvg(_unraidActivity.ParityCheckPercent ?? 0)
                            }
                            else
                            {
                                <div class="activity-icon-box activity-icon-box-idle">
                                    <MudIcon Icon="@Icons.Material.Filled.Sync" Size="Size.Large" />
                                </div>
                            }
                            <div class="usage-row-copy">
                                <div class="usage-row-title">@ParityRollupLabel()</div>
                                <div class="usage-row-used">@ParityStatusLabel()</div>
                            </div>
                        </div>
                    </div>
                }

                <div class="metrics-column-splitter" aria-hidden="true"></div>

                <div class="usage-stack usage-stack-compact metrics-column">
                    <div class="usage-row">
                        <div class="activity-icon-box activity-icon-box-idle">
                            <MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Large" />
                        </div>
                        <div class="usage-row-copy">
                            <div class="usage-row-title">Uptime</div>
                            <div class="usage-row-used">@UptimeRollupLabel()</div>
                        </div>
                    </div>
                    <div class="usage-stack-divider" aria-hidden="true"></div>
                    <div class="usage-row usage-row-clickable" @onclick="@(() => ToggleDetail("stuck"))" title="Processes blocked waiting on storage — open for details">
                        <div class="activity-icon-box @((_unraidActivity?.StuckProcesses.Count ?? 0) > 0 ? "activity-icon-box-alert" : "activity-icon-box-idle")">
                            <MudIcon Icon="@Icons.Material.Filled.HourglassBottom" Size="Size.Large" />
                        </div>
                        <div class="usage-row-copy">
                            <div class="usage-row-title">Blocked on storage</div>
                            <div class="usage-row-used">@StuckProcessesLabel()</div>
                        </div>
                    </div>
                </div>
            }
            </div>
        </div>
        }

        @if (_networkDetailOpen)
        {
            <div class="network-bandwidth-panels-row">
                <NetworkBandwidthDetailPanel @key="NetworkBandwidthDirection.Download"
                                             Direction="NetworkBandwidthDirection.Download"
                                             Sessions="Sessions"
                                             OnClose="CloseNetworkDetail" />
                <NetworkBandwidthDetailPanel @key="NetworkBandwidthDirection.Upload"
                                             Direction="NetworkBandwidthDirection.Upload"
                                             Sessions="Sessions"
                                             OnClose="CloseNetworkDetail" />
            </div>
        }
    </MudPaper>

@code {
    [Parameter] public IReadOnlyList<ServiceHealth> Services { get; set; } = [];
    [Parameter] public IReadOnlyList<ActiveSession> Sessions { get; set; } = [];

    private bool _networkDetailOpen;

    private void ToggleNetworkDetail() => _networkDetailOpen = !_networkDetailOpen;
    private void CloseNetworkDetail() => _networkDetailOpen = false;

    private const string PanelId = "server-metrics";
    private const int ChartWidth = 640;
    private const int ChartHeight = 72;
    private const double PlotLeft = 8;
    private const double PlotRight = ChartWidth - 8;
    private const double PlotTop = 0;
    private const double PlotBottom = ChartHeight;
    private const double RingRadius = 30;
    private static readonly double RingCircumference = 2 * Math.PI * RingRadius;
    private static readonly int EnvMetricsPollDefault =
        int.TryParse(Environment.GetEnvironmentVariable("ARRDASH_METRICS_POLL_SECONDS"), out var seconds)
            ? Math.Clamp(seconds, 1, 60)
            : 2;
    private static readonly int EnvMetricsGraphWindowDefault =
        int.TryParse(Environment.GetEnvironmentVariable("ARRDASH_METRICS_GRAPH_MINUTES"), out var minutes)
            ? Math.Clamp(minutes, 5, 240)
            : 15;
    [Parameter] public ServerMetrics? Metrics { get; set; }
    [Parameter] public DateTimeOffset SampledAt { get; set; }
    [Parameter] public string? SelectedServiceKey { get; set; }
    [Parameter] public EventCallback<string?> SelectedServiceKeyChanged { get; set; }

    private ServerMetrics? _liveMetrics;
    private ServerMetrics EffectiveMetrics => DisplayMetrics ?? PlaceholderMetrics;
    private ServerMetrics PlaceholderMetrics => new(
        HostSystemMetricsService.ResolveLabel(Prefs.Current),
        null,
        null,
        0,
        0,
        0,
        0,
        0,
        0);
    private ServerMetrics? DisplayMetrics => _liveMetrics ?? Metrics;
    private bool HostMetricsLoading => DisplayMetrics is null;
    private bool ActivityLoading => _unraidActivity is null;
    private bool ShowUnraidActivitySections => _unraidActivity?.IsUnraidHost != false;
    private const string LoadingLabel = "Loading…";
    private static readonly IReadOnlyList<string> EmptyContainerNames = [];

    private readonly double[] _gridLines = [YForPercent(100), YForPercent(50), YForPercent(0)];
    private IReadOnlyList<CoreUsage> _coreUsage = [];
    private string? _selectedDetail;
    private CancellationTokenSource _pollCts = new();
    private int _pollIntervalSeconds = EnvMetricsPollDefault;
    private int _graphWindowMinutes = EnvMetricsGraphWindowDefault;
    private static readonly int[] GraphWindowChoices = [5, 10, 15];

    private void SelectGraphWindow(int minutes)
    {
        _graphWindowMinutes = minutes;
        RebuildCpuChart();
    }
    private double? _displayCpu;
    private double? _displayIoWait;
    private string _linePath = "";
    private string _ioWaitLinePath = "";
    private string _areaPath = "";
    private PlotPoint? _latestPoint;
    private string _windowStartLabel = "";
    private HoverState? _hover;
    private ElementReference _plotRef;
    private System.Threading.Timer? _scrollTimer;
    private Task? _pollLoopTask;
    private static readonly TimeSpan UnraidActivityRefreshInterval = TimeSpan.FromSeconds(5);
    private UnraidActivity? _unraidActivity;
    private DateTimeOffset _unraidActivityLoadedAt;
    private bool _unraidActivityLoading;

    private bool RolledUp => Prefs.IsPanelRolledUp(PanelId);
    private string ShellClass => RolledUp ? "server-metrics-bar is-rolled-up" : "server-metrics-bar";
    private IReadOnlyList<double> SparkSamples =>
        CpuHistory.GetSamples(TimeSpan.FromMinutes(2)).Select(sample => sample.Percent).TakeLast(24).ToList();

    private async Task ToggleRollup() => await Prefs.TogglePanelRollupAsync(PanelId);

    protected override void OnInitialized()
    {
        _pollIntervalSeconds = Prefs.GetMetricsPollIntervalSeconds(EnvMetricsPollDefault);
        _graphWindowMinutes = Prefs.GetMetricsGraphWindowMinutes(EnvMetricsGraphWindowDefault);
        Prefs.Changed += OnPrefsChanged;

        _scrollTimer = new System.Threading.Timer(_ =>
        {
            _ = InvokeAsync(() =>
            {
                RebuildCpuChart();
                StateHasChanged();
            });
            _ = RefreshUnraidActivityAsync(force: false);
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));

        RestartPollLoop();
        _ = RefreshUnraidActivityAsync(force: true);
    }

    private void OnPrefsChanged()
    {
        var nextPoll = Prefs.GetMetricsPollIntervalSeconds(EnvMetricsPollDefault);
        var nextWindow = Prefs.GetMetricsGraphWindowMinutes(EnvMetricsGraphWindowDefault);
        var pollChanged = nextPoll != _pollIntervalSeconds;
        var windowChanged = nextWindow != _graphWindowMinutes;

        _pollIntervalSeconds = nextPoll;
        _graphWindowMinutes = nextWindow;

        if (windowChanged)
            RebuildCpuChart();

        if (pollChanged)
            _ = InvokeAsync(RestartPollLoop);
        else if (windowChanged)
            _ = InvokeAsync(StateHasChanged);
    }

    private void RestartPollLoop()
    {
        _pollCts.Cancel();
        _pollCts.Dispose();
        _pollCts = new CancellationTokenSource();
        _pollLoopTask = PollLoopAsync();
    }

    private async Task RefreshUnraidActivityAsync(bool force)
    {
        if (_unraidActivityLoading)
            return;

        if (!force && DateTimeOffset.UtcNow - _unraidActivityLoadedAt < UnraidActivityRefreshInterval)
            return;

        _unraidActivityLoading = true;
        try
        {
            var activity = await UnraidActivityService.ReadAsync(CancellationToken.None);
            _unraidActivity = activity;
            _unraidActivityLoadedAt = DateTimeOffset.UtcNow;
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _unraidActivityLoading = false;
        }
    }

