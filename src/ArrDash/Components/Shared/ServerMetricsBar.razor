    private static int? ParseCoreId(string label)
    {
        const string prefix = "Core ";
        return label.StartsWith(prefix, StringComparison.OrdinalIgnoreCase) &&
            int.TryParse(label[prefix.Length..], out var id)
            ? id
            : null;
    }

