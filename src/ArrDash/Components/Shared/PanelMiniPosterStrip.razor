@using ArrDash.Models

<div class="panel-mini-poster-strip" aria-hidden="true">
    @foreach (var item in PreviewItems)
    {
        <div class="mini-poster" title="@item.Title">
            @if (!string.IsNullOrWhiteSpace(item.PosterUrl))
            {
                <img src="@item.PosterUrl" alt="" loading="lazy" />
            }
            else
            {
                <span class="mini-poster-fallback">@Initials(item.Title)</span>
            }
        </div>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<DownloadItem> Items { get; set; } = [];
    [Parameter] public int MaxItems { get; set; } = 8;

    private IEnumerable<DownloadItem> PreviewItems =>
        Items.Take(MaxItems);

    private static string Initials(string title)
    {
        var parts = title.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant()
            : title.Length >= 2 ? title[..2].ToUpperInvariant() : "?";
    }
}
