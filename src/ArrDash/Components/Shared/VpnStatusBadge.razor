@implements IDisposable
@inject IJSRuntime Js
@inject IConfiguration Configuration

@if (!string.IsNullOrWhiteSpace(ResolvedUrl))
{
    <span class="vpn-status-badge @StatusClass" title="@Tooltip">
        <MudIcon Icon="@Icons.Material.Filled.VpnLock" Size="Size.Small" />
        @StatusLabel
    </span>
}

@code {
    /// <summary>Explicit status endpoint; falls back to ArrDash:VpnStatusUrl config
    /// (ARRDASH_VPN_STATUS_URL). Badge is hidden entirely when neither is set.</summary>
    [Parameter] public string StatusUrl { get; set; } = "";

    private static readonly TimeSpan PollInterval = TimeSpan.FromSeconds(20);

    private bool? _connected;
    private System.Threading.Timer? _timer;

    private string? ResolvedUrl => string.IsNullOrWhiteSpace(StatusUrl)
        ? Configuration["ArrDash:VpnStatusUrl"]
        : StatusUrl;

    private string StatusClass => _connected switch
    {
        true => "vpn-status-on",
        false => "vpn-status-off",
        _ => "vpn-status-unknown"
    };

    private string StatusLabel => _connected switch
    {
        true => "VPN",
        false => "No VPN",
        _ => "VPN ?"
    };

    private string Tooltip => _connected switch
    {
        true => "This connection is routed through the VPN allowlist",
        false => "This connection is not in the VPN allowlist",
        _ => "Could not reach VPN status service"
    };

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(ResolvedUrl))
            return;

        _timer = new System.Threading.Timer(async _ => await PollAsync(), null, TimeSpan.Zero, PollInterval);
    }

    private async Task PollAsync()
    {
        var url = ResolvedUrl;
        if (string.IsNullOrWhiteSpace(url))
            return;

        bool? connected;
        try
        {
            connected = await Js.InvokeAsync<bool?>("arrdashVpn.checkStatus", url, 4000);
        }
        catch
        {
            connected = null;
        }

        _connected = connected;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => _timer?.Dispose();
}
