@inject IJSRuntime Js
@implements IAsyncDisposable

<button type="button"
        class="back-to-top-pill back-to-top-pill-page @(_visible ? "is-visible" : null)"
        aria-label="Back to top of page"
        @onclick="ScrollToTopAsync">
    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" />
    <span>Top</span>
</button>

@code {
    [Parameter] public int ThresholdPixels { get; set; } = 400;

    private DotNetObjectReference<PageBackToTop>? _dotNet;
    private bool _visible;
    private bool _attached;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _attached)
            return;

        _dotNet = DotNetObjectReference.Create(this);
        try
        {
            await Js.InvokeVoidAsync("arrdashBackToTop.attachWindow", _dotNet, ThresholdPixels);
            _attached = true;
        }
        catch
        {
            // Ignore disconnects during navigation / first paint races.
        }
    }

    [JSInvokable]
    public Task OnBackToTopVisibility(bool visible)
    {
        if (_visible == visible)
            return Task.CompletedTask;

        _visible = visible;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ScrollToTopAsync()
    {
        try
        {
            await Js.InvokeVoidAsync("arrdashBackToTop.scrollWindowToTop");
        }
        catch
        {
            // Ignore disconnects during navigation.
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_attached)
        {
            try
            {
                await Js.InvokeVoidAsync("arrdashBackToTop.detachWindow");
            }
            catch
            {
                // Circuit may already be gone.
            }
        }

        _dotNet?.Dispose();
        _dotNet = null;
        _attached = false;
    }
}
