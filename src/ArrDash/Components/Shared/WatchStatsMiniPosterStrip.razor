@using ArrDash.Models

<div class="watch-stats-mini-poster-strip">
    @foreach (var row in Rows.Take(MaxItems))
    {
        <div class="mini-poster" title="@Tooltip(row)">
            @{
                var (primary, secondary) = ThumbSources(row);
            }
            @if (primary is not null)
            {
                @* Dead/expired posters fail client-side; arrdashThumb tries the fallback URL,
                   then the initials tile. *@
                <img src="@primary" alt="" loading="lazy"
                     data-fallback="@secondary"
                     onerror="arrdashThumb.onError(this)" onload="arrdashThumb.onLoad(this)" />
                <span class="mini-poster-fallback mini-poster-fallback-hidden">@Initials(row.Title)</span>
            }
            else
            {
                <span class="mini-poster-fallback">@Initials(row.Title)</span>
            }
            @if (row.Plays > 1)
            {
                <span class="mini-poster-count">×@row.Plays</span>
            }
        </div>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<WatchStatRow> Rows { get; set; } = [];
    [Parameter] public int MaxItems { get; set; } = 8;

    private static (string? Primary, string? Secondary) ThumbSources(WatchStatRow row) =>
        !string.IsNullOrWhiteSpace(row.ThumbUrl)
            ? (row.ThumbUrl, string.IsNullOrWhiteSpace(row.FallbackThumbUrl) ? null : row.FallbackThumbUrl)
            : !string.IsNullOrWhiteSpace(row.FallbackThumbUrl)
                ? (row.FallbackThumbUrl, null)
                : (null, null);

    private static string Tooltip(WatchStatRow row) =>
        string.IsNullOrWhiteSpace(row.Subtitle) ? row.Title : $"{row.Title} — {row.Subtitle}";

    private static string Initials(string title)
    {
        var parts = title.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant()
            : title.Length >= 2 ? title[..2].ToUpperInvariant() : "?";
    }
}
