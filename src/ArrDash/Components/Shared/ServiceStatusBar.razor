@using ArrDash.Models
@using ArrDash.Services
@using MudBlazor

<div class="service-status-wrap">
    @if (FilteredServices.Count > 0)
    {
        <MudPaper Class="@BarClass" Elevation="0">
            @foreach (var service in FilteredServices)
            {
                var tooltip = GetTooltip(service, SampledAt);
                var isSelected = string.Equals(SelectedServiceKey, service.Key, StringComparison.OrdinalIgnoreCase);
                <MudTooltip Text="@tooltip" Disabled="@string.IsNullOrWhiteSpace(tooltip)" Placement="Placement.Top">
                    <div class="status-chip @GetChipClass(service) @(isSelected ? "is-selected" : "")"
                         role="button"
                         tabindex="0"
                         @onclick="@(() => ToggleService(service.Key))"
                         @onkeydown="@(e => OnChipKeyDown(e, service.Key))">
                        <span class="status-dot"></span>
                        <span class="status-name">@service.Name</span>
                        @if (service.Workload is { Kind: not ServiceWorkloadKind.None } workload)
                        {
                            <MudIcon Icon="@GetWorkloadIcon(workload.Kind)"
                                     Size="Size.Small"
                                     Class="@GetWorkloadIconClass(workload.Kind)" />
                        }
                        @if (NeedsAttentionBadge(service))
                        {
                            <MudIcon Icon="@Icons.Material.Filled.WarningAmber"
                                     Size="Size.Small"
                                     Class="status-attention-icon" />
                        }
                    </div>
                </MudTooltip>
            }
        </MudPaper>
    }

    @if (!string.IsNullOrWhiteSpace(SelectedServiceKey))
    {
        <ServiceDetailPanel ServiceKey="@SelectedServiceKey"
                            ServiceDisplayName="@SelectedServiceDisplayName"
                            OnClose="ClearSelection" />
    }
</div>

@code {
    private static readonly HashSet<string> HideVersionKeys = new(StringComparer.OrdinalIgnoreCase)
    {
        "sonarr",
        "radarr",
        "chaptarr"
    };

    [Parameter] public IReadOnlyList<ServiceHealth> Services { get; set; } = [];
    [Parameter] public DateTimeOffset? SampledAt { get; set; }
    [Parameter] public StatusBarMode Mode { get; set; } = StatusBarMode.All;
    [Parameter] public StatusBarAlignment Alignment { get; set; } = StatusBarAlignment.Left;
    [Parameter] public string? SelectedServiceKey { get; set; }
    [Parameter] public EventCallback<string?> SelectedServiceKeyChanged { get; set; }

    private string BarClass => Alignment switch
    {
        StatusBarAlignment.Right => "status-bar status-bar-align-right",
        StatusBarAlignment.SpacedEvenly => "status-bar status-bar-align-spaced",
        _ => "status-bar status-bar-align-left"
    };

    private IReadOnlyList<ServiceHealth> FilteredServices => Mode switch
    {
        StatusBarMode.OfflineOnly => Services.Where(s => s.Configured && !s.Online).ToList(),
        StatusBarMode.Hidden => [],
        _ => Services
    };

    private string? SelectedServiceDisplayName =>
        string.IsNullOrWhiteSpace(SelectedServiceKey)
            ? null
            : Services.FirstOrDefault(s => string.Equals(s.Key, SelectedServiceKey, StringComparison.OrdinalIgnoreCase))?.Name
              ?? SelectedServiceKey;

    private async Task ToggleService(string key)
    {
        var next = string.Equals(SelectedServiceKey, key, StringComparison.OrdinalIgnoreCase) ? null : key;
        await SelectedServiceKeyChanged.InvokeAsync(next);
    }

    private async Task ClearSelection() => await SelectedServiceKeyChanged.InvokeAsync(null);

    private async Task OnChipKeyDown(KeyboardEventArgs e, string key)
    {
        if (e.Key is "Enter" or " ")
            await ToggleService(key);
    }

    private static bool NeedsAttentionBadge(ServiceHealth service) =>
        !service.Online && service.Configured;

    private static string GetChipClass(ServiceHealth service)
    {
        if (!service.Configured)
            return "pending";

        return service.Online ? "online" : "offline";
    }

    private static string? GetTooltip(ServiceHealth service, DateTimeOffset? sampledAt)
    {
        var parts = new List<string> { "Click for details" };

        if (service.Workload is { Kind: not ServiceWorkloadKind.None } workload)
        {
            parts.Add(workload.Label);
            if (sampledAt is { } at)
                parts.Add($"Checked {TimeDisplayHelper.FormatRefreshRelative(at)}");
        }

        if (!service.Configured)
        {
            parts.Add("Not configured");
            return string.Join("\n", parts);
        }

        if (!service.Online && !string.IsNullOrWhiteSpace(service.Error))
            parts.Add(service.Error);

        if (!HideVersionKeys.Contains(service.Key) && !string.IsNullOrWhiteSpace(service.Version))
            parts.Add($"v{service.Version}");

        return string.Join("\n", parts);
    }

    private static string GetWorkloadIcon(ServiceWorkloadKind kind) => kind switch
    {
        ServiceWorkloadKind.Searching => Icons.Material.Filled.ManageSearch,
        ServiceWorkloadKind.Importing => Icons.Material.Filled.Publish,
        ServiceWorkloadKind.Downloading => Icons.Material.Filled.CloudDownload,
        ServiceWorkloadKind.Scanning => Icons.Material.Filled.FolderOpen,
        ServiceWorkloadKind.Matching => Icons.Material.Filled.AutoFixHigh,
        ServiceWorkloadKind.Syncing => Icons.Material.Filled.Sync,
        ServiceWorkloadKind.Transcoding => Icons.Material.Filled.Memory,
        _ => Icons.Material.Filled.MoreHoriz
    };

    private static string GetWorkloadIconClass(ServiceWorkloadKind kind)
    {
        var classes = "status-activity-icon is-active";
        if (kind is ServiceWorkloadKind.Syncing or ServiceWorkloadKind.Searching)
            classes += " is-sync";

        return classes;
    }
}
