@using ArrDash.Models
@using ArrDash.Services
@implements IDisposable
@inject UnraidActivityService UnraidActivityService

<div class="network-speed-graph" title="Network throughput">
    <MiniUsageRing Class="mini-usage-ring-lg"
                   Label="↓"
                   Detail="@FormatThroughput(_latest?.RxBytesPerSecond ?? 0)"
                   Percent="@RxPercent"
                   Color="#35c5f4" />
    <MiniUsageRing Class="mini-usage-ring-lg"
                   Label="↑"
                   Detail="@FormatThroughput(_latest?.TxBytesPerSecond ?? 0)"
                   Percent="@TxPercent"
                   Color="#f5c518" />
</div>

@code {
    [Parameter] public int MaxSamples { get; set; } = 24;

    private static readonly TimeSpan PollInterval = TimeSpan.FromSeconds(5);

    private readonly List<long> _rxSamples = [];
    private readonly List<long> _txSamples = [];
    private NetworkThroughput? _latest;
    private System.Threading.Timer? _timer;

    private double RxPercent => Percent(_latest?.RxBytesPerSecond ?? 0);
    private double TxPercent => Percent(_latest?.TxBytesPerSecond ?? 0);

    protected override void OnInitialized()
    {
        _timer = new System.Threading.Timer(async _ => await PollAsync(), null, TimeSpan.Zero, PollInterval);
    }

    private async Task PollAsync()
    {
        var activity = await UnraidActivityService.ReadAsync(CancellationToken.None);
        if (activity?.Network is not { } net)
            return;

        _latest = net;
        AddSample(_rxSamples, net.RxBytesPerSecond);
        AddSample(_txSamples, net.TxBytesPerSecond);

        await InvokeAsync(StateHasChanged);
    }

    private void AddSample(List<long> samples, long value)
    {
        samples.Add(value);
        if (samples.Count > MaxSamples)
            samples.RemoveAt(0);
    }

    private double Percent(long value)
    {
        var max = Math.Max(1L, Math.Max(_rxSamples.DefaultIfEmpty(0).Max(), _txSamples.DefaultIfEmpty(0).Max()));
        return Math.Clamp((double)value / max * 100, 0, 100);
    }

    private static string FormatThroughput(long bytesPerSecond) => $"{ByteDisplayHelper.Format(bytesPerSecond)}/s";

    public void Dispose() => _timer?.Dispose();
}
